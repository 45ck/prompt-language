Goal: R34 local PL server-only integration lane with deterministic FSCRUD-01 domain, UI, and handoff artifacts

memory:
  fscrud_workspace
  fscrud_task
  fscrud_r34_policy

flow:
  remember key="fscrud_workspace" value="workspace/fscrud-01"
  remember key="fscrud_task" value="TASK.md"
  remember key="fscrud_r34_policy" value="R34 local-only server integration lane; deterministic domain kernel, deterministic UI skeleton, README, run manifest, and verification report are protected; local model owns server.js only"

  let protected_files = "workspace/fscrud-01/src/domain.js, workspace/fscrud-01/public/index.html, workspace/fscrud-01/package.json, workspace/fscrud-01/CONTRACT.md, workspace/fscrud-01/DOMAIN_API.md, workspace/fscrud-01/contracts/domain-exports.json, workspace/fscrud-01/__tests__/domain.contract.test.js, workspace/fscrud-01/data/seed.json, workspace/fscrud-01/scripts/check-domain-exports.cjs, workspace/fscrud-01/scripts/check-domain-customer.cjs, workspace/fscrud-01/scripts/check-domain-assets.cjs, workspace/fscrud-01/scripts/check-domain-work-orders.cjs, workspace/fscrud-01/README.md, workspace/fscrud-01/run-manifest.json, workspace/fscrud-01/verification-report.md"
  let allowed_files = "workspace/fscrud-01/src/server.js"
  let task_contract = "FSCRUD-01 field-service work order tracker. Domain behavior, static UI surface, and handoff docs are already provided and must not be edited. The measured risk is local-model server integration reliability only."
  let integration_contract = "Build a CommonJS HTTP server in src/server.js that imports ./domain.js, serves public/index.html for browser access, and exposes JSON CRUD endpoints or clearly named route handlers for customers, assets, and work_orders. Preserve deterministic UI, domain, docs, manifest, and report files exactly."

  run: node -e "const fs=require('fs');const cp=require('child_process');const paths=['experiments/fullstack-crud-comparison/scaffold/write-scaffold-contract.cjs','../../../../../fullstack-crud-comparison/scaffold/write-scaffold-contract.cjs'];const script=paths.find((p)=>fs.existsSync(p));if(!script){console.error('scaffold script missing');process.exit(1)}const r=cp.spawnSync(process.execPath,[script,'workspace/fscrud-01'],{stdio:'inherit'});process.exit(r.status??1)" [timeout 60]
  run: node -e "const fs=require('fs');const cp=require('child_process');const paths=['experiments/fullstack-crud-comparison/scaffold/write-domain-kernel.cjs','../../../../../fullstack-crud-comparison/scaffold/write-domain-kernel.cjs'];const script=paths.find((p)=>fs.existsSync(p));if(!script){console.error('domain kernel script missing');process.exit(1)}const r=cp.spawnSync(process.execPath,[script,'workspace/fscrud-01'],{stdio:'inherit'});process.exit(r.status??1)" [timeout 60]
  run: node -e "const fs=require('fs');const ui='<!doctype html>\\n<html lang=\"en\">\\n  <head><meta charset=\"utf-8\"><title>FSCRUD-01 deterministic UI skeleton</title></head>\\n  <body>\\n    <h1>FSCRUD-01 Field Service Work Orders</h1>\\n    <section id=\"customers\" data-entity=\"customers\">customers customerId list create read edit detail delete table rows browse view all add new update modify save show remove archive</section>\\n    <section id=\"assets\" data-entity=\"assets\">assets assetId customerId list create read edit detail delete table rows browse view all add new update modify save show remove archive</section>\\n    <section id=\"work_orders\" data-entity=\"work_orders\">work_orders work orders workOrder customerId assetId status open scheduled in_progress completed cancelled priority low normal urgent completedAt list create read edit detail delete table rows browse view all add new update modify save show remove archive</section>\\n  </body>\\n</html>\\n';fs.writeFileSync('workspace/fscrud-01/public/index.html',ui);" [timeout 60]
  run: node -e "const fs=require('fs');const cp=require('child_process');const paths=['experiments/fullstack-crud-comparison/scaffold/write-r34-handoff-artifacts.cjs','../../../../../fullstack-crud-comparison/scaffold/write-r34-handoff-artifacts.cjs'];const script=paths.find((p)=>fs.existsSync(p));if(!script){console.error('R34 handoff script missing');process.exit(1)}const r=cp.spawnSync(process.execPath,[script,'workspace/fscrud-01'],{stdio:'inherit'});process.exit(r.status??1)" [timeout 60]
  run: cd workspace/fscrud-01 && npm run check:domain:exports && npm run check:domain:customer && npm run check:domain:assets && npm run check:domain:work-orders && npm test [timeout 300]
  run: node -e "require('fs').rmSync('workspace/fscrud-01/src/server.js',{force:true});" [timeout 60]

  prompt: Work only in ${fscrud_workspace}. Treat workspace/fscrud-01 as the app root. EXPERIMENT_ARM r34-pl-server-only-integration. PROVIDER local-only. Deterministic domain kernel, deterministic UI skeleton, README, run-manifest.json, and verification-report.md are already implemented and green. Do not edit protected files: ${protected_files}. Create or repair only this file: ${allowed_files}. ${integration_contract} Task contract: ${task_contract}.
  review strict criteria: "Local server integration file must exist, preserve deterministic domain/UI/docs/manifest/report artifacts, pass public domain checks and tests, and expose customers, assets, and work_orders server integration." grounded-by "node ../../../../../fullstack-crud-comparison/scaffold/verify-r33-public.cjs workspace/fscrud-01" max 3
    prompt: Work only in ${fscrud_workspace}. Treat workspace/fscrud-01 as the app root. Repair only workspace/fscrud-01/src/server.js. Do not edit protected files: ${protected_files}. Critique: ${_review_critique}
  end

  run: node -e "require('fs').writeFileSync('workspace/fscrud-01/.pl-r34-server-only-integration-complete','ok\n')" [timeout 60]

done when:
  file_exists workspace/fscrud-01/package.json
  file_exists workspace/fscrud-01/DOMAIN_API.md
  file_exists workspace/fscrud-01/contracts/domain-exports.json
  file_exists workspace/fscrud-01/README.md
  file_exists workspace/fscrud-01/src/domain.js
  file_exists workspace/fscrud-01/src/server.js
  file_exists workspace/fscrud-01/public/index.html
  file_exists workspace/fscrud-01/__tests__/domain.contract.test.js
  file_exists workspace/fscrud-01/data/seed.json
  file_exists workspace/fscrud-01/run-manifest.json
  file_exists workspace/fscrud-01/verification-report.md
  file_exists workspace/fscrud-01/.pl-r34-server-only-integration-complete

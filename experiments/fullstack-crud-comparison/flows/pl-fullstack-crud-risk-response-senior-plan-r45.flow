Goal: R45 local PL senior risk-response diagnostic with deterministic FSCRUD-01 product behavior

memory:
  fscrud_workspace
  fscrud_task
  fscrud_r45_policy

flow:
  remember key="fscrud_workspace" value="workspace/fscrud-01"
  remember key="fscrud_task" value="TASK.md"
  remember key="fscrud_r45_policy" value="R45 local-only bounded senior risk-response lane; deterministic domain kernel, deterministic UI skeleton, and deterministic server integration are protected; local model owns senior-plan.risk-response.txt only; deterministic scorer validates risk-response ranking plus bounded criteria terms and renders senior-plan.raw.json, canonical handoff-source.json, and final handoff artifacts"

  let protected_files = "workspace/fscrud-01/src/domain.js, workspace/fscrud-01/src/server.js, workspace/fscrud-01/public/index.html, workspace/fscrud-01/package.json, workspace/fscrud-01/CONTRACT.md, workspace/fscrud-01/DOMAIN_API.md, workspace/fscrud-01/contracts/domain-exports.json, workspace/fscrud-01/__tests__/domain.contract.test.js, workspace/fscrud-01/data/seed.json, workspace/fscrud-01/scripts/check-domain-exports.cjs, workspace/fscrud-01/scripts/check-domain-customer.cjs, workspace/fscrud-01/scripts/check-domain-assets.cjs, workspace/fscrud-01/scripts/check-domain-work-orders.cjs"
  let risk_response_contract = "Create workspace/fscrud-01/senior-plan.risk-response.txt. Rank three senior risk responses from best to worst for the known FSCRUD local-model failure modes. Criteria weights: path-root isolation=5, seed integrity=5, schema repair=4, handoff artifacts=4, deterministic verification=4, protected local scope=3. Options: guard-path-seed-schema-handoff means protect local product files and prioritize path root isolation, seed integrity, schema repair, handoff artifacts, deterministic verification; expand-editable-product-scope means allow broader local edits before stable checks; defer-verification-to-manual-review means use manual review instead of deterministic checks. Write three ranked lines only. The first line must include path root isolation, seed integrity, schema repair, handoff artifacts, deterministic verification, protected local. Do not create senior-plan.raw.json, handoff-source.json, README.md, run-manifest.json, or verification-report.md."

  run: node -e "const fs=require('fs');const cp=require('child_process');const paths=['experiments/fullstack-crud-comparison/scaffold/write-scaffold-contract.cjs','../../../../../fullstack-crud-comparison/scaffold/write-scaffold-contract.cjs'];const script=paths.find((p)=>fs.existsSync(p));if(!script){console.error('scaffold script missing');process.exit(1)}const r=cp.spawnSync(process.execPath,[script,'workspace/fscrud-01'],{stdio:'inherit'});process.exit(r.status??1)" [timeout 60]
  run: node -e "const fs=require('fs');const cp=require('child_process');const paths=['experiments/fullstack-crud-comparison/scaffold/write-domain-kernel.cjs','../../../../../fullstack-crud-comparison/scaffold/write-domain-kernel.cjs'];const script=paths.find((p)=>fs.existsSync(p));if(!script){console.error('domain kernel script missing');process.exit(1)}const r=cp.spawnSync(process.execPath,[script,'workspace/fscrud-01'],{stdio:'inherit'});process.exit(r.status??1)" [timeout 60]
  run: node -e "const fs=require('fs');const ui='<!doctype html>\\n<html lang=\"en\">\\n  <head><meta charset=\"utf-8\"><title>FSCRUD-01 deterministic UI skeleton</title></head>\\n  <body>\\n    <h1>FSCRUD-01 Field Service Work Orders</h1>\\n    <section id=\"customers\" data-entity=\"customers\">customers customerId list create read edit detail delete table rows browse view all add new update modify save show remove archive</section>\\n    <section id=\"assets\" data-entity=\"assets\">assets assetId customerId list create read edit detail delete table rows browse view all add new update modify save show remove archive</section>\\n    <section id=\"work_orders\" data-entity=\"work_orders\">work_orders work orders workOrder customerId assetId status open scheduled in_progress completed cancelled priority low normal urgent completedAt list create read edit detail delete table rows browse view all add new update modify save show remove archive</section>\\n  </body>\\n</html>\\n';fs.writeFileSync('workspace/fscrud-01/public/index.html',ui);" [timeout 60]
  run: node -e "const fs=require('fs');const cp=require('child_process');const paths=['experiments/fullstack-crud-comparison/scaffold/write-r35-server-artifact.cjs','../../../../../fullstack-crud-comparison/scaffold/write-r35-server-artifact.cjs'];const script=paths.find((p)=>fs.existsSync(p));if(!script){console.error('R45 server script missing');process.exit(1)}const r=cp.spawnSync(process.execPath,[script,'workspace/fscrud-01'],{stdio:'inherit'});process.exit(r.status??1)" [timeout 60]
  run: cd workspace/fscrud-01 && npm run check:domain:exports && npm run check:domain:customer && npm run check:domain:assets && npm run check:domain:work-orders && npm test [timeout 300]
  run: node -e "const fs=require('fs');for(const p of ['workspace/fscrud-01/README.md','workspace/fscrud-01/run-manifest.json','workspace/fscrud-01/verification-report.md','workspace/fscrud-01/handoff-source.json','workspace/fscrud-01/senior-plan.raw.json','workspace/fscrud-01/senior-plan.risk-response.txt'])fs.rmSync(p,{force:true});" [timeout 60]

  prompt: Work only in ${fscrud_workspace}. Treat workspace/fscrud-01 as the app root. EXPERIMENT_ARM r45-pl-risk-response-senior-plan-source. PROVIDER local-only. Use one write_file action to create only workspace/fscrud-01/senior-plan.risk-response.txt. Do not edit protected files: ${protected_files}. Do not create senior-plan.raw.json, handoff-source.json, README.md, run-manifest.json, or verification-report.md. Contract: ${risk_response_contract}
  review strict criteria: "senior-plan.risk-response.txt must exist only at workspace/fscrud-01/senior-plan.risk-response.txt, rank guard first, expand second, manual third, and include the required top-candidate risk terms." grounded-by "node ../../../../../fullstack-crud-comparison/scaffold/normalize-r45-risk-response-source.cjs workspace/fscrud-01 --check-only" max 3
    prompt: Work only in ${fscrud_workspace}. Repair only workspace/fscrud-01/senior-plan.risk-response.txt. Use one write_file action. Use exactly these three lines: 1=guard-path-seed-schema-handoff because path root isolation, seed integrity, schema repair, handoff artifacts, deterministic verification, and protected local scope reduce the known risk.; 2=expand-editable-product-scope because broader local edits can help only after protected checks are stable.; 3=defer-verification-to-manual-review because manual review is weaker than deterministic verification. Do not edit protected files: ${protected_files}. Do not write senior-plan.raw.json, handoff-source.json, README.md, run-manifest.json, or verification-report.md. Critique: ${_review_critique}
  end

  run: node ../../../../../fullstack-crud-comparison/scaffold/normalize-r45-risk-response-source.cjs workspace/fscrud-01 [timeout 60]
  run: node ../../../../../fullstack-crud-comparison/scaffold/verify-r45-risk-response-source.cjs workspace/fscrud-01 [timeout 60]
  run: node ../../../../../fullstack-crud-comparison/scaffold/write-r36-handoff-artifacts.cjs workspace/fscrud-01 [timeout 60]
  run: node ../../../../../fullstack-crud-comparison/scaffold/verify-r35-public.cjs workspace/fscrud-01 [timeout 60]

  run: node -e "require('fs').writeFileSync('workspace/fscrud-01/.pl-r45-risk-response-senior-plan-complete','ok\n')" [timeout 60]

done when:
  file_exists workspace/fscrud-01/package.json
  file_exists workspace/fscrud-01/DOMAIN_API.md
  file_exists workspace/fscrud-01/contracts/domain-exports.json
  file_exists workspace/fscrud-01/README.md
  file_exists workspace/fscrud-01/src/domain.js
  file_exists workspace/fscrud-01/src/server.js
  file_exists workspace/fscrud-01/public/index.html
  file_exists workspace/fscrud-01/__tests__/domain.contract.test.js
  file_exists workspace/fscrud-01/data/seed.json
  file_exists workspace/fscrud-01/senior-plan.risk-response.txt
  file_exists workspace/fscrud-01/senior-plan.raw.json
  file_exists workspace/fscrud-01/handoff-source.json
  file_exists workspace/fscrud-01/run-manifest.json
  file_exists workspace/fscrud-01/verification-report.md
  file_exists workspace/fscrud-01/.pl-r45-risk-response-senior-plan-complete

Goal: Build a complete, brand-compliant marketing website for CloudPulse. Output a single index.html file that passes all quality, content, and brand voice checks.

flow:
  # Phase 1: Brand context setup
  let product_name = "CloudPulse"
  let tagline = "Monitor smarter, respond faster."
  let primary_color = "#2563EB"
  let secondary_color = "#7C3AED"
  let accent_color = "#10B981"
  let dark_color = "#1E293B"
  let light_color = "#F8FAFC"

  # Phase 2: Generate website with retry loop for quality enforcement
  retry max 3
    prompt: |
      Create a complete marketing website for ${product_name} as a single index.html file.

      BRAND RULES (strict — violations cause rejection):
      - Product name is EXACTLY "${product_name}" — never "Cloud Pulse", "Cloudpulse", "cloud pulse", or "CLOUDPULSE"
      - Even in CSS class names, use "cp-" prefix instead of "cloudpulse" (e.g. class="cp-hero" not class="cloudpulse-hero")
      - Tagline: "${tagline}"
      - No exclamation marks anywhere in visible text
      - No filler words: very, really, just, basically, actually, simply, literally, quite, rather
      - All headings in Title Case (capitalize first letter of each major word)
      - CTA buttons use action verbs: Get, Start, Deploy, Monitor, Launch, Discover
      - Sentences under 20 words average
      - Professional, confident tone throughout

      REQUIRED SECTIONS (all must be present with correct id attributes):
      1. <nav> — sticky navigation with links to #hero, #features, #pricing, #testimonials
      2. <section id="hero"> — headline, subheadline with tagline, primary CTA button, stats bar
      3. <section id="features"> — at least 3 feature cards with inline SVG icons
      4. <section id="pricing"> — at least 2 pricing tiers (e.g. Starter, Pro) with feature lists and CTA buttons
      5. <section id="testimonials"> — at least 2 customer quotes with <blockquote>, name, and company
      6. <footer id="footer"> — contact email, social links (Twitter, LinkedIn, GitHub)

      TECHNICAL REQUIREMENTS:
      - <!DOCTYPE html> declaration
      - <meta name="viewport" content="width=device-width, initial-scale=1.0">
      - All CSS inline in <style> tag, no external stylesheets
      - @media (max-width: 768px) responsive rules
      - Colors: primary ${primary_color}, secondary ${secondary_color}, accent ${accent_color}, dark ${dark_color}, light ${light_color}
      - No <img> tags — use inline SVGs or CSS gradients only
      - All nav links must use #anchor-id format matching section ids

      Write the complete index.html file now.

    # Validate HTML structure
    run: node -e "const fs=require('fs');if(!fs.existsSync('index.html')){console.error('index.html not found');process.exit(1)};const h=fs.readFileSync('index.html','utf8');const issues=[];if(!h.includes('<!DOCTYPE html>'))issues.push('missing DOCTYPE');if(!/meta[^>]*viewport[^>]*width=device-width/i.test(h))issues.push('missing viewport meta');if(!/@media[^{]*max-width/i.test(h))issues.push('no mobile media queries');['hero','features','pricing','testimonials'].forEach(s=>{if(!new RegExp('id=[\"\\x27]'+s+'[\"\\x27]','i').test(h))issues.push('missing section id='+s)});if(!/<nav/i.test(h))issues.push('missing nav element');if(!/<footer/i.test(h))issues.push('missing footer element');if(!/<blockquote/i.test(h))issues.push('no blockquote in testimonials');const anchors=(h.match(/href=[\"']#([^\"']+)[\"']/g)||[]);const ids=new Set((h.match(/id=[\"']([^\"']+)[\"']/g)||[]).map(m=>m.match(/id=[\"']([^\"']+)[\"']/)[1]));const broken=anchors.filter(a=>{const t=a.match(/href=[\"']#([^\"']+)[\"']/)[1];return!ids.has(t)});if(broken.length)issues.push('broken anchor links: '+broken.join(', '));if(issues.length){console.error('VALIDATION FAILED:\\n'+issues.map(i=>'  - '+i).join('\\n'));process.exit(1)}else{console.log('STRUCTURE: PASS (all checks clear)')}"

    if command_failed
      prompt: |
        The HTML structure validation failed. Here are the issues:
        ${last_stderr}

        Fix ALL listed issues in index.html. Do not skip any. Key reminders:
        - Each section needs an id attribute: id="hero", id="features", id="pricing", id="testimonials"
        - Nav anchors must match existing section ids
        - Testimonials need <blockquote> elements
        - Must have DOCTYPE, viewport meta, and @media queries
    end

    # Validate brand voice
    run: node -e "const fs=require('fs');const h=fs.readFileSync('index.html','utf8');const text=h.replace(/<style[^>]*>[\\s\\S]*?<\\/style>/gi,'').replace(/<script[^>]*>[\\s\\S]*?<\\/script>/gi,'').replace(/<[^>]+>/g,' ').replace(/\\s+/g,' ');const issues=[];const fillers=['very','really','just','basically','actually','simply','literally','quite','rather'];fillers.forEach(f=>{const re=new RegExp('\\\\b'+f+'\\\\b','gi');const m=text.match(re);if(m)issues.push('filler word \"'+f+'\" found '+m.length+' time(s)')});const excl=(text.match(/[A-Za-z][^.!?]*!/g)||[]).filter(e=>!/function|var |let |const |===|!==/.test(e));if(excl.length>0)issues.push(excl.length+' exclamation mark(s) in body copy');const wrong=(text.match(/cloud\\s+pulse|Cloud\\s+Pulse|CLOUDPULSE/gi)||[]);if(wrong.length)issues.push('wrong product name variants: '+wrong.join(', '));const cssWrong=(h.match(/cloudpulse/gi)||[]).filter(m=>m!=='CloudPulse');if(cssWrong.length)issues.push(cssWrong.length+' lowercase \"cloudpulse\" in code (use cp- prefix)');if(issues.length){console.error('BRAND CHECK FAILED:\\n'+issues.map(i=>'  - '+i).join('\\n'));process.exit(1)}else{console.log('BRAND: PASS (voice checks clear)')}"

    if command_failed
      prompt: |
        The brand voice check failed. Here are the issues:
        ${last_stderr}

        Fix ALL brand voice issues in index.html:
        - Replace any filler words (very, really, just, basically, etc.)
        - Remove exclamation marks from visible text
        - Product name must be exactly "CloudPulse" everywhere — even CSS classes should use "cp-" prefix, not "cloudpulse"
        - Check every heading, paragraph, and button text
    end
  end

  # Phase 3: Final content completeness check
  run: node -e "const fs=require('fs');const h=fs.readFileSync('index.html','utf8');const issues=[];const cards=(h.match(/<(div|article)[^>]*class=[\"'][^\"']*(?:feature|card)[^\"']*[\"']/gi)||[]).length;const h3s=(h.match(/<h3/gi)||[]).length;if(Math.max(cards,h3s)<3)issues.push('fewer than 3 feature cards/items');const prices=(h.match(/\\$\\d+|free|starter|pro|enterprise|basic|premium/gi)||[]);if(prices.length<2)issues.push('fewer than 2 pricing tier indicators');const quotes=(h.match(/<blockquote/gi)||[]).length;if(quotes<2)issues.push('fewer than 2 testimonial blockquotes');const social=(h.match(/twitter|linkedin|github|x\\.com/gi)||[]);if(social.length<2)issues.push('fewer than 2 social links');if(issues.length){console.error('CONTENT CHECK FAILED:\\n'+issues.map(i=>'  - '+i).join('\\n'));process.exit(1)}else{console.log('CONTENT: PASS (all sections complete)')}"

  if command_failed
    prompt: |
      Content completeness check failed:
      ${last_stderr}

      Fix the missing content in index.html. Ensure:
      - At least 3 feature cards (with class="cp-feature" or similar + <h3> titles)
      - At least 2 pricing tiers with price indicators ($X/mo or Free)
      - At least 2 testimonial <blockquote> elements
      - Social links for Twitter, LinkedIn, and GitHub in the footer
  end

done when:
  file_exists index.html

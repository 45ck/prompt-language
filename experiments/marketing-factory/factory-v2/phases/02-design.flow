library: design

export flow run(product_name):
  # Parallel design: tokens + component library
  spawn "design-engineer"
    prompt: |
      Use agent: design-engineer. Use skills: design-system-architecture, css-custom-properties.

      Read brand-guidelines.md for color palette, typography, and spacing rules.
      Create design-tokens.css with CSS custom properties organized in these categories:

      1. COLORS
         --cp-primary: #2563EB;
         --cp-primary-hover: #1D4ED8;
         --cp-primary-light: #DBEAFE;
         --cp-secondary: #7C3AED;
         --cp-secondary-hover: #6D28D9;
         --cp-secondary-light: #EDE9FE;
         --cp-accent: #10B981;
         --cp-accent-hover: #059669;
         --cp-dark: #1E293B;
         --cp-dark-soft: #334155;
         --cp-light: #F8FAFC;
         --cp-light-alt: #F1F5F9;
         --cp-white: #FFFFFF;
         --cp-border: #E2E8F0;
         --cp-text: #1E293B;
         --cp-text-muted: #64748B;

      2. TYPOGRAPHY
         --cp-font-heading: 'Inter', system-ui, sans-serif;
         --cp-font-body: 'Inter', system-ui, sans-serif;
         --cp-font-mono: 'JetBrains Mono', monospace;
         --cp-text-xs: 0.75rem;
         --cp-text-sm: 0.875rem;
         --cp-text-base: 1rem;
         --cp-text-lg: 1.125rem;
         --cp-text-xl: 1.25rem;
         --cp-text-2xl: 1.5rem;
         --cp-text-3xl: 1.875rem;
         --cp-text-4xl: 2.25rem;
         --cp-text-5xl: 3rem;
         --cp-leading-tight: 1.25;
         --cp-leading-normal: 1.5;
         --cp-leading-relaxed: 1.625;

      3. SPACING
         --cp-space-1: 0.25rem;
         --cp-space-2: 0.5rem;
         --cp-space-3: 0.75rem;
         --cp-space-4: 1rem;
         --cp-space-6: 1.5rem;
         --cp-space-8: 2rem;
         --cp-space-12: 3rem;
         --cp-space-16: 4rem;
         --cp-space-20: 5rem;
         --cp-space-24: 6rem;

      4. LAYOUT
         --cp-max-width: 1200px;
         --cp-radius-sm: 0.375rem;
         --cp-radius-md: 0.5rem;
         --cp-radius-lg: 0.75rem;
         --cp-radius-full: 9999px;
         --cp-shadow-sm: 0 1px 2px rgba(0,0,0,0.05);
         --cp-shadow-md: 0 4px 6px -1px rgba(0,0,0,0.1);
         --cp-shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.1);
         --cp-shadow-xl: 0 20px 25px -5px rgba(0,0,0,0.1);

      5. BREAKPOINTS (as comments — CSS custom properties cannot be used in media queries)
         /* --cp-bp-sm: 640px */
         /* --cp-bp-md: 768px */
         /* --cp-bp-lg: 1024px */
         /* --cp-bp-xl: 1280px */

      Wrap all properties in :root { }. Write design-tokens.css now.
  end

  spawn "component-architect"
    prompt: |
      Use agent: component-architect. Use skills: css-architecture, component-library-design.

      Read brand-guidelines.md for visual rules. You will create components.css with reusable
      component classes that reference design-tokens.css custom properties (var(--cp-*)).

      REQUIRED COMPONENT CLASSES:

      1. .cp-nav — sticky top navigation
         - Background: var(--cp-dark), text white
         - Flexbox: logo left, nav links right, gap 2rem
         - Links: white text, opacity 0.8 default, 1.0 on hover
         - Mobile: hamburger menu at 768px breakpoint
         - Max-width container centered with padding

      2. .cp-hero — hero section
         - Full-width, min-height 80vh, centered content
         - Background: linear gradient from var(--cp-dark) to var(--cp-secondary)
         - h1: var(--cp-text-5xl), white, font-weight 700
         - Subtitle: var(--cp-text-xl), rgba(255,255,255,0.8)
         - Stats bar: 3 columns, white text, border-top separator

      3. .cp-card — feature/content card
         - Background: var(--cp-white), border-radius var(--cp-radius-lg)
         - Shadow: var(--cp-shadow-md), hover var(--cp-shadow-lg)
         - Padding: var(--cp-space-8)
         - Icon circle: 48px, bg var(--cp-primary-light), centered SVG
         - h3: var(--cp-text-xl), margin-bottom var(--cp-space-3)

      4. .cp-pricing-tier — pricing card
         - Two variants: .cp-pricing-tier (standard) and .cp-pricing-tier--featured (highlighted)
         - Featured: border 2px var(--cp-primary), "Most Popular" badge
         - Price: var(--cp-text-4xl), font-weight 700
         - Feature list: checkmark prefix, var(--cp-space-3) gap between items
         - CTA button at bottom

      5. .cp-testimonial — testimonial block
         - Blockquote with left border 4px var(--cp-primary)
         - Quote text: var(--cp-text-lg), italic
         - Attribution: name bold, company in var(--cp-text-muted)
         - Avatar circle placeholder: 48px, bg var(--cp-primary-light)

      6. .cp-footer — site footer
         - Background: var(--cp-dark), text white
         - Grid: 3-4 columns on desktop, stack on mobile
         - Links: rgba(255,255,255,0.7), hover white
         - Social icons row with 1.5rem gap
         - Bottom bar with copyright, border-top separator

      7. .cp-btn — button base + variants
         - .cp-btn: base padding, border-radius, font-weight 600, transition
         - .cp-btn--primary: bg var(--cp-primary), text white, hover var(--cp-primary-hover)
         - .cp-btn--secondary: border var(--cp-primary), text var(--cp-primary), transparent bg
         - .cp-btn--accent: bg var(--cp-accent), text white
         - .cp-btn--lg: larger padding and font size

      8. .cp-section — section wrapper
         - Max-width var(--cp-max-width), centered, padding var(--cp-space-16) vertical
         - .cp-section__title: var(--cp-text-3xl), centered, margin-bottom var(--cp-space-4)
         - .cp-section__subtitle: var(--cp-text-lg), var(--cp-text-muted), centered

      9. .cp-grid — responsive grid
         - .cp-grid--2: 2 columns, .cp-grid--3: 3 columns, .cp-grid--4: 4 columns
         - Gap: var(--cp-space-8)
         - Collapse to 1 column at 768px

      Include @media (max-width: 768px) responsive overrides for all components.
      Write components.css now.
  end

  await all

  # Validate CSS files parse without syntax errors
  review max 2
    run: node -e "const fs=require('fs');const issues=[];['design-tokens.css','components.css'].forEach(f=>{if(!fs.existsSync(f)){issues.push(f+' missing');return}const c=fs.readFileSync(f,'utf8');const open=c.split('{').length;const close=c.split('}').length;if(Math.abs(open-close)>1)issues.push(f+': unbalanced braces ('+open+' open vs '+close+' close)');if(!c.includes(':root')&&f==='design-tokens.css')issues.push(f+': missing :root selector');if(c.length<200)issues.push(f+': suspiciously short ('+c.length+' chars)')});if(issues.length){console.error('CSS VALIDATION FAILED:\\n'+issues.map(i=>'  - '+i).join('\\n'));process.exit(1)}else{console.log('CSS: PASS')}"
    if command_failed
      prompt: |
        CSS validation failed: ${last_stderr}
        Fix the issues in the CSS files. Ensure braces are balanced, design-tokens.css has :root,
        and both files contain substantial content.
    end
  end

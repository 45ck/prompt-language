{
  "formatVersion": 1,
  "id": "helpdesk-smoke",
  "name": "Helpdesk Smoke",
  "startUrl": "http://localhost:3000/sign-in",
  "sessionMode": "fresh",
  "viewports": [
    { "name": "desktop", "width": 1440, "height": 900 },
    { "name": "mobile", "width": 390, "height": 844 }
  ],
  "steps": [
    {
      "kind": "type",
      "name": "Enter email",
      "target": { "kind": "label", "text": "Email" },
      "value": "agent@example.com"
    },
    {
      "kind": "type",
      "name": "Enter password",
      "target": { "kind": "label", "text": "Password" },
      "value": "Password123!"
    },
    {
      "kind": "click",
      "name": "Sign in",
      "target": { "kind": "role", "role": "button", "name": "Sign in" }
    },
    {
      "kind": "waitFor",
      "condition": { "kind": "url", "pattern": "**/inbox" }
    },
    {
      "kind": "click",
      "name": "New ticket",
      "target": { "kind": "role", "role": "button", "name": "New ticket" }
    },
    {
      "kind": "type",
      "name": "Ticket subject",
      "target": { "kind": "label", "text": "Subject" },
      "value": "Printer not connecting"
    },
    {
      "kind": "type",
      "name": "Requester email",
      "target": { "kind": "label", "text": "Requester email" },
      "value": "jamie@acme.test"
    },
    {
      "kind": "click",
      "name": "Save ticket",
      "target": { "kind": "role", "role": "button", "name": "Save ticket" }
    },
    {
      "kind": "assert",
      "name": "Ticket visible",
      "assertion": { "kind": "textPresent", "text": "Printer not connecting" }
    }
  ],
  "assertions": [
    { "kind": "noCriticalA11yViolations" }
  ],
  "policies": {
    "consoleErrors": { "max": 0, "allowMessages": [] },
    "networkFailures": { "max": 0, "allowUrls": [] },
    "pageErrors": { "max": 0, "allowMessages": [] },
    "performance": { "maxPageLoadMs": 4000 },
    "accessibility": { "maxCritical": 0 }
  }
}

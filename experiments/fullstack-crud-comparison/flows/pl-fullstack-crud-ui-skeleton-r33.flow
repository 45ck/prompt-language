Goal: R33 local PL integration lane with deterministic FSCRUD-01 domain kernel and UI skeleton

memory:
  fscrud_workspace
  fscrud_task
  fscrud_r33_policy

flow:
  remember key="fscrud_workspace" value="workspace/fscrud-01"
  remember key="fscrud_task" value="TASK.md"
  remember key="fscrud_r33_policy" value="R33 local-only integration lane; deterministic domain kernel and deterministic UI skeleton are protected; local model owns server docs report wiring only"

  let protected_files = "workspace/fscrud-01/src/domain.js, workspace/fscrud-01/public/index.html, workspace/fscrud-01/package.json, workspace/fscrud-01/CONTRACT.md, workspace/fscrud-01/DOMAIN_API.md, workspace/fscrud-01/contracts/domain-exports.json, workspace/fscrud-01/__tests__/domain.contract.test.js, workspace/fscrud-01/data/seed.json, workspace/fscrud-01/scripts/check-domain-exports.cjs, workspace/fscrud-01/scripts/check-domain-customer.cjs, workspace/fscrud-01/scripts/check-domain-assets.cjs, workspace/fscrud-01/scripts/check-domain-work-orders.cjs"
  let allowed_files = "workspace/fscrud-01/src/server.js, workspace/fscrud-01/README.md, workspace/fscrud-01/run-manifest.json, workspace/fscrud-01/verification-report.md"
  let task_contract = "FSCRUD-01 field-service work order tracker. Domain behavior and static UI surface are already provided and must not be edited. The measured risk is local-model integration reliability across server routes, documentation, manifest, and final verification notes."
  let integration_contract = "Build a CommonJS HTTP server in src/server.js that imports ./domain.js, serves public/index.html for browser access, and exposes JSON CRUD endpoints or clearly named route handlers for customers, assets, and work_orders. Preserve deterministic UI and domain files exactly."

  run: node -e "const fs=require('fs');const cp=require('child_process');const paths=['experiments/fullstack-crud-comparison/scaffold/write-scaffold-contract.cjs','../../../../../fullstack-crud-comparison/scaffold/write-scaffold-contract.cjs'];const script=paths.find((p)=>fs.existsSync(p));if(!script){console.error('scaffold script missing');process.exit(1)}const r=cp.spawnSync(process.execPath,[script,'workspace/fscrud-01'],{stdio:'inherit'});process.exit(r.status??1)" [timeout 60]
  run: node -e "const fs=require('fs');const cp=require('child_process');const paths=['experiments/fullstack-crud-comparison/scaffold/write-domain-kernel.cjs','../../../../../fullstack-crud-comparison/scaffold/write-domain-kernel.cjs'];const script=paths.find((p)=>fs.existsSync(p));if(!script){console.error('domain kernel script missing');process.exit(1)}const r=cp.spawnSync(process.execPath,[script,'workspace/fscrud-01'],{stdio:'inherit'});process.exit(r.status??1)" [timeout 60]
  run: node -e "const fs=require('fs');const ui='<!doctype html>\\n<html lang=\"en\">\\n  <head><meta charset=\"utf-8\"><title>FSCRUD-01 deterministic UI skeleton</title></head>\\n  <body>\\n    <h1>FSCRUD-01 Field Service Work Orders</h1>\\n    <section id=\"customers\" data-entity=\"customers\">customers customerId list create read edit detail delete table rows browse view all add new update modify save show remove archive</section>\\n    <section id=\"assets\" data-entity=\"assets\">assets assetId customerId list create read edit detail delete table rows browse view all add new update modify save show remove archive</section>\\n    <section id=\"work_orders\" data-entity=\"work_orders\">work_orders work orders workOrder customerId assetId status open scheduled in_progress completed cancelled priority low normal urgent completedAt list create read edit detail delete table rows browse view all add new update modify save show remove archive</section>\\n  </body>\\n</html>\\n';fs.writeFileSync('workspace/fscrud-01/public/index.html',ui);" [timeout 60]
  run: cd workspace/fscrud-01 && npm run check:domain:exports && npm run check:domain:customer && npm run check:domain:assets && npm run check:domain:work-orders && npm test [timeout 300]
  run: node -e "const fs=require('fs');for(const p of ['workspace/fscrud-01/src/server.js','workspace/fscrud-01/README.md','workspace/fscrud-01/run-manifest.json','workspace/fscrud-01/verification-report.md'])fs.rmSync(p,{force:true});" [timeout 60]

  prompt: Work only in ${fscrud_workspace}. Treat workspace/fscrud-01 as the app root. EXPERIMENT_ARM r33-pl-ui-skeleton-integration. PROVIDER local-only. Deterministic domain kernel and deterministic UI skeleton are already implemented and green. Do not edit protected files: ${protected_files}. Create or repair only these files: ${allowed_files}. ${integration_contract} README must document npm test, npm start, and the deterministic domain/UI protection policy. run-manifest.json must record r33-pl-ui-skeleton-integration, deterministic-domain-kernel, deterministic-ui-skeleton, protected-artifacts, and local-only integration. verification-report.md must list public checks run by the flow and say the hidden verifier is run only by the harness. Task contract: ${task_contract}.
  review strict criteria: "Local integration files must exist, preserve the deterministic domain kernel and UI skeleton, pass public domain checks and tests, and label the R33 deterministic-domain plus deterministic-UI policy in docs and manifest." grounded-by 'node -e "const fs=require(\"fs\");if(fs.existsSync(\"src/domain.js\")||fs.existsSync(\"public/index.html\")){console.error(\"run_root_leak\");process.exit(1)}for(const p of [\"workspace/fscrud-01/src/server.js\",\"workspace/fscrud-01/public/index.html\",\"workspace/fscrud-01/README.md\",\"workspace/fscrud-01/run-manifest.json\",\"workspace/fscrud-01/verification-report.md\"]){if(!fs.existsSync(p)){console.error(\"missing_file:\"+p);process.exit(1)}}const domain=fs.readFileSync(\"workspace/fscrud-01/src/domain.js\",\"utf8\");if(domain.includes(\"not implemented\")){console.error(\"domain_kernel_not_preserved\");process.exit(1)}const ui=fs.readFileSync(\"workspace/fscrud-01/public/index.html\",\"utf8\").toLowerCase();for(const term of [\"customers\",\"assets\",\"work_orders\",\"list\",\"create\",\"edit\",\"detail\",\"delete\",\"customerid\",\"assetid\",\"status\",\"open\",\"scheduled\",\"in_progress\",\"completed\",\"cancelled\",\"priority\",\"low\",\"normal\",\"urgent\",\"completedat\"]){if(!ui.includes(term)){console.error(\"ui_skeleton_term_missing:\"+term);process.exit(1)}}const server=fs.readFileSync(\"workspace/fscrud-01/src/server.js\",\"utf8\").toLowerCase();for(const term of [\"require('./domain.js')\",\"customers\",\"assets\",\"work_orders\"]){if(!server.includes(term)){console.error(\"server_term_missing:\"+term);process.exit(1)}}const manifest=fs.readFileSync(\"workspace/fscrud-01/run-manifest.json\",\"utf8\").toLowerCase();for(const term of [\"r33-pl-ui-skeleton-integration\",\"deterministic-domain-kernel\",\"deterministic-ui-skeleton\",\"local-only\"]){if(!manifest.includes(term)){console.error(\"manifest_term_missing:\"+term);process.exit(1)}}const readme=fs.readFileSync(\"workspace/fscrud-01/README.md\",\"utf8\").toLowerCase();if(!readme.includes(\"npm test\")||!readme.includes(\"npm start\")||!readme.includes(\"deterministic\")){console.error(\"readme_missing_policy_or_commands\");process.exit(1)}const report=fs.readFileSync(\"workspace/fscrud-01/verification-report.md\",\"utf8\").toLowerCase();if(!report.includes(\"check:domain:exports\")||!report.includes(\"hidden verifier\")){console.error(\"verification_report_missing_checks\");process.exit(1)}" && cd workspace/fscrud-01 && npm run check:domain:exports && npm run check:domain:customer && npm run check:domain:assets && npm run check:domain:work-orders && npm test' max 4
    prompt: Work only in ${fscrud_workspace}. Treat workspace/fscrud-01 as the app root. Repair only these allowed files: ${allowed_files}. Do not edit protected files: ${protected_files}. Keep the deterministic UI skeleton untouched. Critique: ${_review_critique}
  end

  run: node -e "require('fs').writeFileSync('workspace/fscrud-01/.pl-r33-ui-skeleton-integration-complete','ok\n')" [timeout 60]

done when:
  file_exists workspace/fscrud-01/package.json
  file_exists workspace/fscrud-01/DOMAIN_API.md
  file_exists workspace/fscrud-01/contracts/domain-exports.json
  file_exists workspace/fscrud-01/README.md
  file_exists workspace/fscrud-01/src/domain.js
  file_exists workspace/fscrud-01/src/server.js
  file_exists workspace/fscrud-01/public/index.html
  file_exists workspace/fscrud-01/__tests__/domain.contract.test.js
  file_exists workspace/fscrud-01/data/seed.json
  file_exists workspace/fscrud-01/run-manifest.json
  file_exists workspace/fscrud-01/verification-report.md
  file_exists workspace/fscrud-01/.pl-r33-ui-skeleton-integration-complete

Goal: Build a brand-compliant marketing website for CloudPulse — a cloud monitoring SaaS platform.

flow:
  # ── Brand identity (single source of truth for interpolation) ──
  let product_name = "CloudPulse"
  let tagline = "Monitor smarter, respond faster."
  let primary_color = "#2563EB"
  let secondary_color = "#7C3AED"
  let accent_color = "#10B981"
  let dark_color = "#1E293B"
  let light_color = "#F8FAFC"

  # ── Phase 1: Research — understand the product and define brand voice ──
  prompt: |
    Research what a cloud monitoring SaaS called ${product_name} ("${tagline}") would need for a marketing website.
    Write brand-guidelines.md covering:
    - Brand voice and tone rules (professional, concise, no filler words)
    - Approved color palette: ${primary_color}, ${secondary_color}, ${accent_color}, ${dark_color}, ${light_color}
    - Typography and spacing conventions
    - CTA style (action-verb driven)
    - Product name usage rules ("${product_name}" is always one word)

  # ── Phase 2: Content strategy — plan what goes on the page ──
  prompt: |
    Based on brand-guidelines.md, create content-brief.md planning the ${product_name} marketing site.
    Decide what sections are needed, what copy each section should contain, and how many
    features/pricing tiers/testimonials to include. Follow the brand voice rules strictly.

  # ── Phase 3: Build — implement as a single index.html ──
  prompt: |
    Build the ${product_name} marketing website as a single self-contained index.html file.
    Read brand-guidelines.md and content-brief.md for all content and style decisions.

    Technical constraints:
    - Single HTML file, all CSS inlined in <style>, no external dependencies
    - Semantic HTML (<header>, <nav>, <main>, <section>, <footer>)
    - Responsive design with media queries
    - CSS custom properties for all brand colors
    - SEO: meta description, Open Graph tags, canonical URL, favicon, JSON-LD schema
    - Accessibility: lang attribute, ARIA labels, heading hierarchy (one h1, h2 for sections, h3 for items)
    - No <img> tags — use inline SVGs and CSS for visuals
    - Every section needs an id attribute for anchor navigation

  # ── Phase 4: Quality gate loop — validate and fix ──
  retry max 3
    # Structure check
    run: node -e "const fs=require('fs');if(!fs.existsSync('index.html')){process.exit(1)};const h=fs.readFileSync('index.html','utf8');const i=[];if(!h.includes('<!DOCTYPE html>'))i.push('missing DOCTYPE');if(!/meta[^>]*viewport/i.test(h))i.push('missing viewport');if(!/@media/i.test(h))i.push('no media queries');if(!/<nav/i.test(h))i.push('no nav');if(!/<main/i.test(h))i.push('no main');if(!/<footer/i.test(h))i.push('no footer');if(!/<html[^>]*lang/i.test(h))i.push('no lang attr');const h1s=(h.match(/<h1/gi)||[]).length;if(h1s!==1)i.push(h1s+' h1 tags (need 1)');if(i.length){console.error('STRUCTURE FAIL:\\n'+i.join('\\n'));process.exit(1)}else console.log('STRUCTURE: PASS')"

    # SEO check
    run: node -e "const fs=require('fs');const h=fs.readFileSync('index.html','utf8');const i=[];if(!/<meta[^>]*name=[\"']description/i.test(h))i.push('no meta description');if(!/<meta[^>]*og:title/i.test(h))i.push('no og:title');if(!/<meta[^>]*og:description/i.test(h))i.push('no og:description');if(!h.includes('canonical'))i.push('no canonical');if(!h.includes('application/ld+json'))i.push('no JSON-LD');if(!/<link[^>]*rel=[\"']icon/i.test(h))i.push('no favicon');if(i.length){console.error('SEO FAIL:\\n'+i.join('\\n'));process.exit(1)}else console.log('SEO: PASS')"

    # Brand voice check
    run: node -e "const fs=require('fs');const h=fs.readFileSync('index.html','utf8');const t=h.replace(/<style[^>]*>[\s\S]*?<\/style>/gi,'').replace(/<script[^>]*>[\s\S]*?<\/script>/gi,'').replace(/<[^>]+>/g,' ').replace(/\s+/g,' ');const i=[];['very','really','just','basically','actually','simply','literally','quite','rather'].forEach(f=>{if(new RegExp('\\b'+f+'\\b','i').test(t))i.push('filler: '+f)});if((t.match(/[A-Za-z][^.!?]*!/g)||[]).filter(e=>!/function|var |let |const /.test(e)).length>0)i.push('exclamation marks found');const wr=(t.match(/cloud\s+pulse|Cloud\s+Pulse|CLOUDPULSE/gi)||[]);if(wr.length)i.push('wrong product name: '+wr.join(', '));if(i.length){console.error('BRAND FAIL:\\n'+i.join('\\n'));process.exit(1)}else console.log('BRAND: PASS')"

    # Color palette check — only brand colors and their shades allowed
    run: node -e "const fs=require('fs');const h=fs.readFileSync('index.html','utf8');const css=h.match(/<style[^>]*>([\s\S]*?)<\/style>/gi);if(!css){process.exit(0)};const s=css.join('');const colors=s.match(/#[0-9a-fA-F]{3,6}\b/g)||[];const bad=colors.filter(c=>{const x=c.slice(1).toLowerCase();const n=x.length===3?x[0]+x[0]+x[1]+x[1]+x[2]+x[2]:x;const r=parseInt(n.slice(0,2),16),g=parseInt(n.slice(2,4),16),b=parseInt(n.slice(4,6),16);if(isNaN(r))return false;if(Math.abs(r-g)<=15&&Math.abs(g-b)<=15)return false;const hues=[[37,99,235],[124,58,237],[16,185,129],[30,41,59],[248,250,252]];return!hues.some(([hr,hg,hb])=>{const dr=Math.abs(r-hr),dg=Math.abs(g-hg),db=Math.abs(b-hb);return Math.max(dr,dg,db)<100&&(r>g===hr>hg)&&(b>g===hb>hg)})});if(bad.length>0){console.error('OFF-PALETTE:\\n'+[...new Set(bad)].join('\\n'));process.exit(1)}else console.log('COLORS: PASS')"

    if command_failed
      prompt: |
        Quality checks failed with these issues:
        ${last_stderr}

        Read the error output carefully and fix every issue in index.html.
        Do not introduce new issues while fixing — re-read brand-guidelines.md if needed.
    end
  end

done when:
  file_exists index.html

Goal: run the E4 repo-local CRM factory experiment with prompt-language as the orchestration layer

memory:
  crm_target_market
  crm_stack
  preferred_package_manager
  experiment_runner
  experiment_candidate
  experiment_workspace

import "experiments/full-saas-factory/e4-codex-crm-factory/libraries/discovery.flow" as discovery
import "experiments/full-saas-factory/e4-codex-crm-factory/libraries/architecture.flow" as architecture
import "experiments/full-saas-factory/e4-codex-crm-factory/libraries/implementation.flow" as implementation
import "experiments/full-saas-factory/e4-codex-crm-factory/libraries/quality.flow" as quality
import "experiments/full-saas-factory/e4-codex-crm-factory/libraries/release.flow" as release

flow:
  remember key="crm_target_market" value="Newcastle and Hunter SMEs with sales and service workflows"
  remember key="crm_stack" value="Next.js + TypeScript + PostgreSQL + Prisma"
  remember key="preferred_package_manager" value="pnpm"
  remember key="experiment_runner" value="codex"
  remember key="experiment_candidate" value="codex+prompt-language"
  remember key="experiment_workspace" value="experiments/full-saas-factory/e4-codex-crm-factory/workspace/crm-app"

  prompt: Work only inside ${experiment_workspace}. Treat it as the target repo root for this experiment. Use the local experiment libraries in this folder as the frozen orchestration surface. Record significant manual interventions in experiments/results/e4-factory using the frozen run id.

  use discovery.bootstrap_workspace()

  spawn "market-research" with vars crm_target_market, crm_stack
    use discovery.market_research()
  end

  spawn "requirements" with vars crm_target_market, crm_stack
    use discovery.requirements_discovery()
  end

  await all

  use architecture.synthesize_scope()

  spawn "backend" with vars crm_stack, preferred_package_manager
    use implementation.backend(pkg_mgr="${preferred_package_manager}")
  end

  spawn "frontend" with vars crm_stack, preferred_package_manager
    use implementation.frontend(pkg_mgr="${preferred_package_manager}")
  end

  spawn "engineering-docs" with vars crm_stack
    use architecture.write_engineering_docs()
  end

  await all

  use quality.local_verification(pkg_mgr="${preferred_package_manager}")
  use quality.manual_qa()
  use quality.product_demo()
  use release.prepare_release(pkg_mgr="${preferred_package_manager}")

done when:
  use quality.crm_ship_gates(pkg_mgr="${preferred_package_manager}")

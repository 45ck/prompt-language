Goal: R43 local PL weighted ranking senior-plan diagnostic with deterministic FSCRUD-01 product behavior

memory:
  fscrud_workspace
  fscrud_task
  fscrud_r43_policy

flow:
  remember key="fscrud_workspace" value="workspace/fscrud-01"
  remember key="fscrud_task" value="TASK.md"
  remember key="fscrud_r43_policy" value="R43 local-only weighted ranking lane; deterministic domain kernel, deterministic UI skeleton, and deterministic server integration are protected; local model owns senior-plan.ranking.txt only; deterministic scorer validates ranked criteria choices and renders senior-plan.raw.json, canonical handoff-source.json, and final handoff artifacts"

  let protected_files = "workspace/fscrud-01/src/domain.js, workspace/fscrud-01/src/server.js, workspace/fscrud-01/public/index.html, workspace/fscrud-01/package.json, workspace/fscrud-01/CONTRACT.md, workspace/fscrud-01/DOMAIN_API.md, workspace/fscrud-01/contracts/domain-exports.json, workspace/fscrud-01/__tests__/domain.contract.test.js, workspace/fscrud-01/data/seed.json, workspace/fscrud-01/scripts/check-domain-exports.cjs, workspace/fscrud-01/scripts/check-domain-customer.cjs, workspace/fscrud-01/scripts/check-domain-assets.cjs, workspace/fscrud-01/scripts/check-domain-work-orders.cjs"
  let ranking_contract = "Create workspace/fscrud-01/senior-plan.ranking.txt. Rank three candidate senior-plan strategies from best to worst using weighted criteria. Criteria weights: protected local-only deterministic files=5, full product coverage for domain UI server seed=5, ordered CRUD relationships=4, executable domain checks and npm tests=4, path seed schema handoff risk coverage=3. Candidates: alpha-frontend-notes-plan means frontend notes only, unordered notes, weak tests, no domain/server/seed coverage; bravo-protected-crud-kernel means protected local-only files, domain UI server seed, ordered CRUD relationships, executable domain checks and npm tests, path seed schema handoff risk coverage; charlie-editable-manual-plan means editable product files, some product coverage, manual inspection only, weak path and schema risk. Write three ranked lines only: 1=<candidate>, 2=<candidate>, 3=<candidate>. Do not create senior-plan.raw.json, handoff-source.json, README.md, run-manifest.json, or verification-report.md."

  run: node -e "const fs=require('fs');const cp=require('child_process');const paths=['experiments/fullstack-crud-comparison/scaffold/write-scaffold-contract.cjs','../../../../../fullstack-crud-comparison/scaffold/write-scaffold-contract.cjs'];const script=paths.find((p)=>fs.existsSync(p));if(!script){console.error('scaffold script missing');process.exit(1)}const r=cp.spawnSync(process.execPath,[script,'workspace/fscrud-01'],{stdio:'inherit'});process.exit(r.status??1)" [timeout 60]
  run: node -e "const fs=require('fs');const cp=require('child_process');const paths=['experiments/fullstack-crud-comparison/scaffold/write-domain-kernel.cjs','../../../../../fullstack-crud-comparison/scaffold/write-domain-kernel.cjs'];const script=paths.find((p)=>fs.existsSync(p));if(!script){console.error('domain kernel script missing');process.exit(1)}const r=cp.spawnSync(process.execPath,[script,'workspace/fscrud-01'],{stdio:'inherit'});process.exit(r.status??1)" [timeout 60]
  run: node -e "const fs=require('fs');const ui='<!doctype html>\\n<html lang=\"en\">\\n  <head><meta charset=\"utf-8\"><title>FSCRUD-01 deterministic UI skeleton</title></head>\\n  <body>\\n    <h1>FSCRUD-01 Field Service Work Orders</h1>\\n    <section id=\"customers\" data-entity=\"customers\">customers customerId list create read edit detail delete table rows browse view all add new update modify save show remove archive</section>\\n    <section id=\"assets\" data-entity=\"assets\">assets assetId customerId list create read edit detail delete table rows browse view all add new update modify save show remove archive</section>\\n    <section id=\"work_orders\" data-entity=\"work_orders\">work_orders work orders workOrder customerId assetId status open scheduled in_progress completed cancelled priority low normal urgent completedAt list create read edit detail delete table rows browse view all add new update modify save show remove archive</section>\\n  </body>\\n</html>\\n';fs.writeFileSync('workspace/fscrud-01/public/index.html',ui);" [timeout 60]
  run: node -e "const fs=require('fs');const cp=require('child_process');const paths=['experiments/fullstack-crud-comparison/scaffold/write-r35-server-artifact.cjs','../../../../../fullstack-crud-comparison/scaffold/write-r35-server-artifact.cjs'];const script=paths.find((p)=>fs.existsSync(p));if(!script){console.error('R43 server script missing');process.exit(1)}const r=cp.spawnSync(process.execPath,[script,'workspace/fscrud-01'],{stdio:'inherit'});process.exit(r.status??1)" [timeout 60]
  run: cd workspace/fscrud-01 && npm run check:domain:exports && npm run check:domain:customer && npm run check:domain:assets && npm run check:domain:work-orders && npm test [timeout 300]
  run: node -e "const fs=require('fs');for(const p of ['workspace/fscrud-01/README.md','workspace/fscrud-01/run-manifest.json','workspace/fscrud-01/verification-report.md','workspace/fscrud-01/handoff-source.json','workspace/fscrud-01/senior-plan.raw.json','workspace/fscrud-01/senior-plan.ranking.txt'])fs.rmSync(p,{force:true});" [timeout 60]

  prompt: Work only in ${fscrud_workspace}. Treat workspace/fscrud-01 as the app root. EXPERIMENT_ARM r43-pl-weighted-ranking-senior-plan-source. PROVIDER local-only. Use one write_file action to create only workspace/fscrud-01/senior-plan.ranking.txt. Do not edit protected files: ${protected_files}. Do not create senior-plan.raw.json, handoff-source.json, README.md, run-manifest.json, or verification-report.md. Contract: ${ranking_contract}
  review strict criteria: "senior-plan.ranking.txt must exist only at workspace/fscrud-01/senior-plan.ranking.txt and must rank candidates by weighted criteria with bravo first, charlie second, alpha third." grounded-by "node ../../../../../fullstack-crud-comparison/scaffold/normalize-r43-weighted-ranking-source.cjs workspace/fscrud-01 --check-only" max 3
    prompt: Work only in ${fscrud_workspace}. Repair only workspace/fscrud-01/senior-plan.ranking.txt. Use one write_file action. Use exactly these three lines: 1=bravo-protected-crud-kernel; 2=charlie-editable-manual-plan; 3=alpha-frontend-notes-plan. Do not edit protected files: ${protected_files}. Do not write senior-plan.raw.json, handoff-source.json, README.md, run-manifest.json, or verification-report.md. Critique: ${_review_critique}
  end

  run: node ../../../../../fullstack-crud-comparison/scaffold/normalize-r43-weighted-ranking-source.cjs workspace/fscrud-01 [timeout 60]
  run: node ../../../../../fullstack-crud-comparison/scaffold/verify-r43-weighted-ranking-source.cjs workspace/fscrud-01 [timeout 60]
  run: node ../../../../../fullstack-crud-comparison/scaffold/write-r36-handoff-artifacts.cjs workspace/fscrud-01 [timeout 60]
  run: node ../../../../../fullstack-crud-comparison/scaffold/verify-r35-public.cjs workspace/fscrud-01 [timeout 60]

  run: node -e "require('fs').writeFileSync('workspace/fscrud-01/.pl-r43-weighted-ranking-senior-plan-complete','ok\n')" [timeout 60]

done when:
  file_exists workspace/fscrud-01/package.json
  file_exists workspace/fscrud-01/DOMAIN_API.md
  file_exists workspace/fscrud-01/contracts/domain-exports.json
  file_exists workspace/fscrud-01/README.md
  file_exists workspace/fscrud-01/src/domain.js
  file_exists workspace/fscrud-01/src/server.js
  file_exists workspace/fscrud-01/public/index.html
  file_exists workspace/fscrud-01/__tests__/domain.contract.test.js
  file_exists workspace/fscrud-01/data/seed.json
  file_exists workspace/fscrud-01/senior-plan.ranking.txt
  file_exists workspace/fscrud-01/senior-plan.raw.json
  file_exists workspace/fscrud-01/handoff-source.json
  file_exists workspace/fscrud-01/run-manifest.json
  file_exists workspace/fscrud-01/verification-report.md
  file_exists workspace/fscrud-01/.pl-r43-weighted-ranking-senior-plan-complete

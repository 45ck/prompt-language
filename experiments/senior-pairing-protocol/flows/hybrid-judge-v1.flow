Goal: Solve the task locally, then use a stronger judge for high-risk senior review

rubric "senior_engineering_quality"
  criterion oracle_correctness type number
  criterion ambiguity_handling type number
  criterion risk_classification type number
  criterion test_quality type number
  criterion minimality type number
  criterion repair_discipline type number
  criterion escalation_judgment type number
end

judge "external_senior_judge"
  kind: model
  rubric: "senior_engineering_quality"
  inputs: [diff, test_output, output]
end

flow:
  run: node -e "process.stdout.write(require('fs').readFileSync('TASK.md','utf8'))" [timeout 60]
  let task_brief = "${last_stdout}"
  let senior_frame = prompt "You are acting as a senior engineer guiding a junior local-model developer. Read the task brief and return JSON with: objective, ambiguity, top_risks, smallest_safe_strategy, tests_to_write, escalation_needed. Runtime can be slow; quality matters more than speed. Task brief: ${task_brief}" as json {
    "objective": "string",
    "ambiguity": "string",
    "top_risks": "string",
    "smallest_safe_strategy": "string",
    "tests_to_write": "string",
    "escalation_needed": "boolean"
  }
  prompt: Implement the task in a tightly supervised style. First inspect the needed files, but do not read or modify verify.js. Then add tests for the risky behavior, then make the smallest production change. Use this senior frame: ${senior_frame}
  until command_succeeded max 3
    run: npm test [timeout 300]
    if command_failed
      prompt: npm test failed. Repair minimally using the actual output. Output: ${last_stdout} ${last_stderr}
    end
  end
  until command_succeeded max 3
    run: node verify.js [timeout 300]
    if command_failed
      prompt: node verify.js failed. State the root cause in one sentence, then repair minimally. Output: ${last_stdout} ${last_stderr}
    end
  end
  run: git diff -- . [timeout 60]
  let diff = "${last_stdout}"
  run: npm test [timeout 300]
  let test_output = "${last_stdout} ${last_stderr}"
  run: node verify.js [timeout 300]
  let output = "${last_stdout} ${last_stderr}"

  spawn "external_reviewer" model "gpt-5.2" with vars senior_frame diff test_output output
    let external_review = prompt "Act as the external senior judge. Review the final diff and deterministic evidence. Return JSON with pass, confidence, reason, concrete_findings, and abstain. Abstain if evidence is insufficient. Senior frame=${senior_frame}; diff=${diff}; npm test output=${test_output}; verify output=${output}" as json {
      "pass": "boolean",
      "confidence": "number",
      "reason": "string",
      "concrete_findings": "string",
      "abstain": "boolean"
    }
  end
  await "external_reviewer" timeout 1200

  review strict using judge "external_senior_judge" max 2
    run: npm test [timeout 300]
    run: node verify.js [timeout 300]
    prompt: Address only concrete findings from external_reviewer.external_review. If deterministic checks pass and the external reviewer has no specific defect, do not rewrite. External review=${external_reviewer.external_review}; critique=${_review_critique}
  end
  prompt: Final handoff: summarize deterministic checks, external reviewer verdict, named-judge verdict, residual risks, and any escalation decision. External review=${external_reviewer.external_review}; named judge pass=${_review_result.pass}; confidence=${_review_result.confidence}; reason=${_review_result.reason}

done when:
  gate tests_pass: npm test
  gate oracle_passes: node verify.js

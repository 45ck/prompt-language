{
  "permissions": {
    "allow": [
      "Read(**)",
      "Grep(**)",
      "Glob(**)",
      "Bash(npm run *)",
      "Bash(npm ci)",
      "Bash(npm install)",
      "Bash(node *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git branch *)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Read(**/*secret*)",
      "Read(**/*credential*)",
      "Bash(rm -rf *)",
      "Bash(*--no-verify*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(*SKIP_CI=*)",
      "Edit(.claude/settings.json)",
      "Edit(.claude/hooks/**)",
      "Edit(eslint.config.mjs)",
      "Edit(vitest.config.ts)",
      "Edit(.dependency-cruiser.cjs)",
      "Edit(tsconfig.json)",
      "Edit(tsconfig.build.json)",
      "Write(.claude/settings.json)",
      "Write(.claude/hooks/**)",
      "Write(eslint.config.mjs)",
      "Write(vitest.config.ts)",
      "Write(.dependency-cruiser.cjs)",
      "Write(tsconfig.json)",
      "Write(tsconfig.build.json)",
      "Bash(*--force*)",
      "Edit(.githooks/**)",
      "Write(.githooks/**)",
      "Edit(AGENTS.md)",
      "Write(AGENTS.md)"
    ]
  }
}

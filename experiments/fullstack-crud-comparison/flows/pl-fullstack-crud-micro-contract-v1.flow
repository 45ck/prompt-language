Goal: build and verify FSCRUD-01 with deterministic scaffold plus micro contract gates

memory:
  fscrud_workspace
  fscrud_task
  fscrud_model_policy

flow:
  remember key="fscrud_workspace" value="workspace/fscrud-01"
  remember key="fscrud_task" value="TASK.md"
  remember key="fscrud_model_policy" value="local Ollama model; runtime speed is telemetry, not a success metric"

  let canonical_exports = "reset, listCustomers, createCustomer, readCustomer, detailCustomer, editCustomer, deleteCustomer, listAssets, createAsset, readAsset, detailAsset, editAsset, deleteAsset, listWorkOrders, createWorkOrder, readWorkOrder, detailWorkOrder, editWorkOrder, deleteWorkOrder"
  let task_contract = "FSCRUD-01 field-service work order tracker. Build customers, assets, and work_orders with list/create/read/edit/detail/delete flows; enforce customer-asset-work_order references, asset/customer mismatch rejection, asset/customer safe deletes, status values open/scheduled/in_progress/completed/cancelled, completedAt rules, priority values low/normal/urgent, seed data, domain validation tests, integration-style tests for each entity family, README, run-manifest.json, and verification-report.md. Prefer a small deterministic Node CommonJS implementation with src/domain.js, src/server.js, public/index.html, and __tests__/domain.contract.test.js before adding framework weight."

  run: node -e "const fs=require('fs');const cp=require('child_process');const paths=['experiments/fullstack-crud-comparison/scaffold/write-scaffold-contract.cjs','../../../../../fullstack-crud-comparison/scaffold/write-scaffold-contract.cjs'];const script=paths.find((p)=>fs.existsSync(p));if(!script){console.error('scaffold script missing');process.exit(1)}const r=cp.spawnSync(process.execPath,[script,'workspace/fscrud-01'],{stdio:'inherit'});process.exit(r.status??1)" [timeout 60]
  try
    run: node -e "const fs=require('fs');for(const p of ['workspace/fscrud-01/package.json','workspace/fscrud-01/CONTRACT.md','workspace/fscrud-01/src/domain.js','workspace/fscrud-01/__tests__/domain.contract.test.js','workspace/fscrud-01/data/seed.json'])if(!fs.existsSync(p)){console.error('missing '+p);process.exit(1)}let moduleExports;try{moduleExports=require('./workspace/fscrud-01/src/domain.js')}catch{console.error('domain_module_load_failed');process.exit(1)}const expected=['reset','listCustomers','createCustomer','readCustomer','detailCustomer','editCustomer','deleteCustomer','listAssets','createAsset','readAsset','detailAsset','editAsset','deleteAsset','listWorkOrders','createWorkOrder','readWorkOrder','detailWorkOrder','editWorkOrder','deleteWorkOrder'].sort();const actual=Object.keys(moduleExports).sort();if(JSON.stringify(actual)!==JSON.stringify(expected)){console.error('module_exports_surface_mismatch');process.exit(1)}for(const name of expected)if(typeof moduleExports[name] !== 'function'){console.error('module_exports_non_function');process.exit(1)}" [timeout 60]
  end

  prompt: Work only in ${fscrud_workspace}. Treat ${fscrud_workspace} as the app root. Senior Micro Contract 1. GOAL replace workspace/fscrud-01/src/domain.js with the smallest complete CommonJS foundation for reset, in-memory stores, id creation, clone safety, and customer CRUD only. FILE workspace/fscrud-01/src/domain.js only. ACTION read_file workspace/fscrud-01/src/domain.js, then write_file workspace/fscrud-01/src/domain.js with one complete replacement. MUST write executable functions, in-memory arrays or maps, ids, and clone safety; do not export entity schemas, class names, model constructors, or placeholder objects. MUST expose exactly these CommonJS module.exports keys, no more and no fewer: ${canonical_exports}. MUST implement listCustomers, createCustomer, readCustomer, detailCustomer, editCustomer, and deleteCustomer. KEEP asset and work_order functions present with the exact names; they may throw not implemented until later micro contracts. Do not create or edit ./src/* at the run root. Task contract: ${task_contract}.
  review strict criteria: "Customer CRUD and exact CommonJS export surface must pass before assets are attempted." grounded-by 'node -e "const fs=require(\"fs\");if(fs.existsSync(\"src/domain.js\")){console.error(\"run_root_src_domain_leak\");process.exit(1)}const d=require(\"./workspace/fscrud-01/src/domain.js\");const expected=[\"reset\",\"listCustomers\",\"createCustomer\",\"readCustomer\",\"detailCustomer\",\"editCustomer\",\"deleteCustomer\",\"listAssets\",\"createAsset\",\"readAsset\",\"detailAsset\",\"editAsset\",\"deleteAsset\",\"listWorkOrders\",\"createWorkOrder\",\"readWorkOrder\",\"detailWorkOrder\",\"editWorkOrder\",\"deleteWorkOrder\"].sort();const actual=Object.keys(d).sort();if(JSON.stringify(actual)!==JSON.stringify(expected)){console.error(\"module_exports_surface_mismatch\");process.exit(1)}d.reset();const c=d.createCustomer({name:\"Acme\",email:\"ops@example.test\",phone:\"555-0100\",serviceAddress:\"1 Field Way\"});if(d.listCustomers().length!==1)throw new Error(\"customer list failed\");if(d.readCustomer(c.id).name!==\"Acme\")throw new Error(\"customer read failed\");if(d.detailCustomer(c.id).id!==c.id)throw new Error(\"customer detail failed\");if(d.editCustomer(c.id,{name:\"Acme 2\"}).name!==\"Acme 2\")throw new Error(\"customer edit failed\");d.deleteCustomer(c.id);if(d.listCustomers().length!==0)throw new Error(\"customer delete failed\");"' max 2
    prompt: Work only in ${fscrud_workspace}. Treat ${fscrud_workspace} as the app root. Repair workspace/fscrud-01/src/domain.js only. FAILED_CHECK: customer micro contract. ALLOWED_FILES: workspace/fscrud-01/src/domain.js. ACTION read_file workspace/fscrud-01/src/domain.js, then write_file workspace/fscrud-01/src/domain.js with one complete CommonJS replacement. If the current file exports schemas, entity objects, undefined variables, classes, or constructors instead of executable CRUD functions, discard that shape and rebuild a function-based in-memory module. Preserve exactly these export names: ${canonical_exports}. Do not create or edit ./src/* at the run root. Critique: ${_review_critique}
  end

  prompt: Work only in ${fscrud_workspace}. Treat ${fscrud_workspace} as the app root. Senior Micro Contract 2. GOAL add asset CRUD to the existing passing workspace/fscrud-01/src/domain.js. FILE workspace/fscrud-01/src/domain.js only. ACTION read_file workspace/fscrud-01/src/domain.js, then write_file workspace/fscrud-01/src/domain.js. MUST keep customer behavior passing unchanged. MUST implement listAssets, createAsset, readAsset, detailAsset, editAsset, and deleteAsset. MUST validate that asset.customerId exists on createAsset and editAsset. MUST preserve exactly these CommonJS module.exports keys: ${canonical_exports}. KEEP work_order functions present with exact names; they may throw not implemented until the next contract. Do not create or edit ./src/* at the run root. Task contract: ${task_contract}.
  review strict criteria: "Asset CRUD must work with customer references while customer CRUD still passes." grounded-by 'node -e "const fs=require(\"fs\");if(fs.existsSync(\"src/domain.js\")){console.error(\"run_root_src_domain_leak\");process.exit(1)}const d=require(\"./workspace/fscrud-01/src/domain.js\");d.reset();const c=d.createCustomer({name:\"Acme\"});const a=d.createAsset({customerId:c.id,name:\"Truck 7\",serialNumber:\"TRK-7\",assetType:\"truck\",installedAt:\"2026-04-30\"});if(d.listAssets().length!==1)throw new Error(\"asset list failed\");if(d.readAsset(a.id).customerId!==c.id)throw new Error(\"asset read failed\");if(d.detailAsset(a.id).id!==a.id)throw new Error(\"asset detail failed\");if(d.editAsset(a.id,{name:\"Truck 7A\"}).name!==\"Truck 7A\")throw new Error(\"asset edit failed\");let rejected=false;try{d.createAsset({customerId:\"missing\",name:\"Bad\"})}catch{rejected=true}if(!rejected)throw new Error(\"asset customer validation failed\");d.deleteAsset(a.id);d.deleteCustomer(c.id);"' max 2
    prompt: Work only in ${fscrud_workspace}. Treat ${fscrud_workspace} as the app root. Repair workspace/fscrud-01/src/domain.js only. FAILED_CHECK: asset micro contract. ACTION read_file workspace/fscrud-01/src/domain.js, then write_file workspace/fscrud-01/src/domain.js. Keep customer behavior and exact export names unchanged. Do not create or edit ./src/* at the run root. Critique: ${_review_critique}
  end

  prompt: Work only in ${fscrud_workspace}. Treat ${fscrud_workspace} as the app root. Senior Micro Contract 3. GOAL add work_order create/read/detail/list behavior to workspace/fscrud-01/src/domain.js. FILE workspace/fscrud-01/src/domain.js only. ACTION read_file workspace/fscrud-01/src/domain.js, then write_file workspace/fscrud-01/src/domain.js. MUST keep customer and asset behavior passing unchanged. MUST implement listWorkOrders, createWorkOrder, readWorkOrder, and detailWorkOrder. MUST reject unknown customerId, unknown assetId, asset/customer mismatch, invalid status, invalid priority, completed without completedAt, and non-completed with completedAt. MUST preserve exactly these CommonJS module.exports keys: ${canonical_exports}. Do not create or edit ./src/* at the run root. Task contract: ${task_contract}.
  review strict criteria: "Work order create/read/detail/list must enforce reference and status rules." grounded-by 'node -e "const fs=require(\"fs\");if(fs.existsSync(\"src/domain.js\")){console.error(\"run_root_src_domain_leak\");process.exit(1)}const d=require(\"./workspace/fscrud-01/src/domain.js\");d.reset();const c1=d.createCustomer({name:\"Acme\"});const c2=d.createCustomer({name:\"Beta\"});const a1=d.createAsset({customerId:c1.id,name:\"Truck 7\"});const a2=d.createAsset({customerId:c2.id,name:\"Pump 2\"});for(const bad of [{customerId:\"missing\",assetId:a1.id,status:\"open\",priority:\"normal\"},{customerId:c1.id,assetId:\"missing\",status:\"open\",priority:\"normal\"},{customerId:c1.id,assetId:a2.id,status:\"open\",priority:\"normal\"},{customerId:c1.id,assetId:a1.id,status:\"bad\",priority:\"normal\"},{customerId:c1.id,assetId:a1.id,status:\"open\",priority:\"bad\"},{customerId:c1.id,assetId:a1.id,status:\"completed\",priority:\"normal\"},{customerId:c1.id,assetId:a1.id,status:\"open\",priority:\"normal\",completedAt:\"2026-04-30T00:00:00Z\"}]){let rejected=false;try{d.createWorkOrder(bad)}catch{rejected=true}if(!rejected)throw new Error(\"work order validation failed\")};const w=d.createWorkOrder({customerId:c1.id,assetId:a1.id,status:\"scheduled\",priority:\"urgent\",title:\"Repair\",description:\"Hydraulic lift\",scheduledFor:\"2026-05-01\"});if(d.listWorkOrders().length!==1)throw new Error(\"work order list failed\");if(d.readWorkOrder(w.id).priority!==\"urgent\")throw new Error(\"work order read failed\");if(d.detailWorkOrder(w.id).assetId!==a1.id)throw new Error(\"work order detail failed\");"' max 2
    prompt: Work only in ${fscrud_workspace}. Treat ${fscrud_workspace} as the app root. Repair workspace/fscrud-01/src/domain.js only. FAILED_CHECK: work_order create/read/detail/list micro contract. ACTION read_file workspace/fscrud-01/src/domain.js, then write_file workspace/fscrud-01/src/domain.js. Keep customer and asset behavior and exact export names unchanged. Do not create or edit ./src/* at the run root. Critique: ${_review_critique}
  end

  prompt: Work only in ${fscrud_workspace}. Treat ${fscrud_workspace} as the app root. Senior Micro Contract 4. GOAL finish work_order edit/delete and safe relationship deletes in workspace/fscrud-01/src/domain.js. FILE workspace/fscrud-01/src/domain.js only. ACTION read_file workspace/fscrud-01/src/domain.js, then write_file workspace/fscrud-01/src/domain.js. MUST keep prior customer, asset, and work_order create/read/detail/list behavior passing unchanged. MUST implement editWorkOrder and deleteWorkOrder. MUST make deleteCustomer and deleteAsset reject deletes while active work_orders reference them. MUST preserve exactly these CommonJS module.exports keys: ${canonical_exports}. CHECK cd workspace/fscrud-01 && npm test. Do not create or edit ./src/* at the run root. Task contract: ${task_contract}.
  review strict criteria: "Full domain contract tests must pass without weakening tests or package scripts." grounded-by 'node -e "if(require(\"fs\").existsSync(\"src/domain.js\")){console.error(\"run_root_src_domain_leak\");process.exit(1)}" && cd workspace/fscrud-01 && npm test' max 3
    prompt: Work only in ${fscrud_workspace}. Treat ${fscrud_workspace} as the app root. Repair workspace/fscrud-01/src/domain.js only. FAILED_CHECK: full domain contract tests. DO_NOT_TOUCH: workspace/fscrud-01/package.json, workspace/fscrud-01/CONTRACT.md, workspace/fscrud-01/__tests__/domain.contract.test.js, workspace/fscrud-01/data/seed.json. ACTION read_file workspace/fscrud-01/src/domain.js, then write_file workspace/fscrud-01/src/domain.js. Preserve exact CommonJS exports and all passing behavior. Do not create or edit ./src/* at the run root. Critique: ${_review_critique}
  end

  prompt: Work only in ${fscrud_workspace}. Treat ${fscrud_workspace} as the app root. Senior Micro Contract 5. GOAL implement minimal HTTP routes in workspace/fscrud-01/src/server.js using the passing domain module. FILE workspace/fscrud-01/src/server.js only. ACTION read_file workspace/fscrud-01/src/server.js, then write_file workspace/fscrud-01/src/server.js. MUST expose GET collection, POST collection, GET /:id, GET /:id/detail, PATCH /:id, and DELETE /:id routes for customers, assets, and work_orders. MUST return JSON errors for validation failures. KEEP domain tests passing and do not edit workspace/fscrud-01/src/domain.js unless npm test names a direct integration break. Do not create or edit ./src/* at the run root. CHECK cd workspace/fscrud-01 && npm test. Task contract: ${task_contract}.
  review strict criteria: "Server slice must mention all route families and preserve passing domain contracts." grounded-by 'node -e "const fs=require(\"fs\");const t=fs.readFileSync(\"workspace/fscrud-01/src/server.js\",\"utf8\").toLowerCase();for(const term of [\"customers\",\"assets\",\"work_orders\",\"list\",\"create\",\"read\",\"edit\",\"detail\",\"delete\"])if(!t.includes(term)){console.error(\"missing server term \"+term);process.exit(1)}" && cd workspace/fscrud-01 && npm test' max 2
    prompt: Work only in ${fscrud_workspace}. Treat ${fscrud_workspace} as the app root. Repair workspace/fscrud-01/src/server.js only unless npm test proves workspace/fscrud-01/src/domain.js regressed. ACTION read_file workspace/fscrud-01/src/server.js, then write_file workspace/fscrud-01/src/server.js. Do not create or edit ./src/* at the run root. Critique: ${_review_critique}
  end

  prompt: Work only in ${fscrud_workspace}. Treat ${fscrud_workspace} as the app root. Senior Micro Contract 6. GOAL make workspace/fscrud-01/public/index.html visibly exercise the API. FILE workspace/fscrud-01/public/index.html only. ACTION read_file workspace/fscrud-01/public/index.html, then write_file workspace/fscrud-01/public/index.html. MUST include visible buttons/forms or controls wired with fetch calls for list/create/read/edit/detail/delete for customers, assets, and work_orders. MUST mention customerId, assetId, status, completedAt, priority, email, phone, serviceAddress, serialNumber, assetType, installedAt, description, and scheduledFor. KEEP tests and source files unchanged. Do not create or edit ./src/* at the run root. Task contract: ${task_contract}.
  review strict criteria: "UI must visibly cover entities, CRUD actions, relationship fields, and required task fields." grounded-by 'node -e "const fs=require(\"fs\");const t=fs.readFileSync(\"workspace/fscrud-01/public/index.html\",\"utf8\").toLowerCase();for(const term of [\"customers\",\"assets\",\"work_orders\",\"list\",\"create\",\"read\",\"edit\",\"detail\",\"delete\",\"customerid\",\"assetid\",\"status\",\"completedat\",\"priority\",\"email\",\"phone\",\"serviceaddress\",\"serialnumber\",\"assettype\",\"installedat\",\"description\",\"scheduledfor\",\"fetch\"])if(!t.includes(term)){console.error(\"missing ui term \"+term);process.exit(1)}"' max 2
    prompt: Work only in ${fscrud_workspace}. Treat ${fscrud_workspace} as the app root. Repair workspace/fscrud-01/public/index.html only. ACTION read_file workspace/fscrud-01/public/index.html, then write_file workspace/fscrud-01/public/index.html. Do not create or edit ./src/* at the run root. Add the missing visible field, operation label, or fetch wiring from the critique. Critique: ${_review_critique}
  end

  prompt: Work only in ${fscrud_workspace}. Treat ${fscrud_workspace} as the app root. Senior Micro Contract 7. GOAL finalize workspace/fscrud-01/README.md, workspace/fscrud-01/run-manifest.json, and workspace/fscrud-01/verification-report.md honestly. FILES workspace/fscrud-01/README.md, workspace/fscrud-01/run-manifest.json, workspace/fscrud-01/verification-report.md only. ACTION read_file each allowed file, then write_file only those files. MUST document npm test, npm start, model/runner placeholders if unknown, and whether the verifier was actually run. KEEP code, tests, seed, and UI unchanged. Do not create or edit ./src/* at the run root. Task contract: ${task_contract}.
  review strict criteria: "Final workspace must pass tests and the hardened FSCRUD verifier." grounded-by 'node -e "const fs=require(\"fs\");const cp=require(\"child_process\");const paths=[\"experiments/fullstack-crud-comparison/verification/verify-fullstack-crud-workspace.mjs\",\"../../../../../fullstack-crud-comparison/verification/verify-fullstack-crud-workspace.mjs\"];const script=paths.find((p)=>fs.existsSync(p));if(!script){console.error(\"verifier script missing\");process.exit(1)}const r=cp.spawnSync(process.execPath,[script,\"--workspace\",\"workspace/fscrud-01\",\"--json\"],{encoding:\"utf8\",stdio:\"inherit\"});process.exit(r.status??1)"' max 2
    prompt: Work only in ${fscrud_workspace}. Treat ${fscrud_workspace} as the app root. Repair only workspace/fscrud-01/README.md, workspace/fscrud-01/run-manifest.json, workspace/fscrud-01/verification-report.md, workspace/fscrud-01/src/domain.js, workspace/fscrud-01/src/server.js, or workspace/fscrud-01/public/index.html when the failing verifier field directly names that file. Never edit workspace/fscrud-01/__tests__, workspace/fscrud-01/package.json, workspace/fscrud-01/CONTRACT.md, or workspace/fscrud-01/data/seed.json. Do not create or edit ./src/* at the run root. Do not weaken tests, seed, package scripts, or contract files. Critique: ${_review_critique}
  end

  run: node -e "require('fs').writeFileSync('workspace/fscrud-01/.pl-micro-contract-complete','ok\n')" [timeout 60]

done when:
  file_exists workspace/fscrud-01/package.json
  file_exists workspace/fscrud-01/CONTRACT.md
  file_exists workspace/fscrud-01/README.md
  file_exists workspace/fscrud-01/src/domain.js
  file_exists workspace/fscrud-01/src/server.js
  file_exists workspace/fscrud-01/public/index.html
  file_exists workspace/fscrud-01/__tests__/domain.contract.test.js
  file_exists workspace/fscrud-01/data/seed.json
  file_exists workspace/fscrud-01/run-manifest.json
  file_exists workspace/fscrud-01/verification-report.md
  file_exists workspace/fscrud-01/.pl-micro-contract-complete

Goal: produce a bounded CRM core slice through prompt-language orchestration

flow:
  prompt: Work only inside the current workspace root. Treat `.factory/` as frozen control input and do not edit it.
  run: npm install

  spawn "research"
    prompt: Write docs/prd.md and docs/acceptance-criteria.md for a bounded CRM core covering contacts, companies, opportunities, stage transitions, tasks, notes, and dashboard summaries. Keep the scope small and implementation-ready.
  end

  spawn "architecture"
    prompt: Write docs/architecture/domain-model.md, docs/api-contracts.md, and specs/invariants.md for the same bounded CRM core. Favor pure TypeScript domain logic and in-memory application services.
  end

  await all

  spawn "domain"
    prompt: Build packages/domain/src/index.ts plus focused tests for contacts, companies, opportunities, stage transitions, tasks, notes, and dashboard summaries.
  end

  spawn "services"
    prompt: Build packages/api/src/index.ts plus focused tests for in-memory application services that create contacts, create opportunities, move stages, add tasks and notes, and compute dashboard summaries.
  end

  await all

  prompt: Write README.md, docs/handover.md, and docs/test-strategy.md from the implemented repo state.
  run: npm run lint
  run: npm run typecheck
  run: npm run test

done when:
  gate lint: npm run lint
  gate typecheck: npm run typecheck
  gate tests: npm run test
  file_exists .factory/project.flow
  file_exists docs/prd.md
  file_exists docs/architecture/domain-model.md
  file_exists docs/api-contracts.md
  file_exists specs/invariants.md
  file_exists packages/domain/src/index.ts
  file_exists packages/api/src/index.ts
  file_exists docs/handover.md

Goal: R31 local PL bulk lane with deterministic FSCRUD-01 domain kernel

memory:
  fscrud_workspace
  fscrud_task
  fscrud_r31_policy

flow:
  remember key="fscrud_workspace" value="workspace/fscrud-01"
  remember key="fscrud_task" value="TASK.md"
  remember key="fscrud_r31_policy" value="R31 local-only bulk lane; deterministic domain kernel is protected; local model owns server UI docs only"

  let protected_files = "workspace/fscrud-01/src/domain.js, workspace/fscrud-01/package.json, workspace/fscrud-01/CONTRACT.md, workspace/fscrud-01/DOMAIN_API.md, workspace/fscrud-01/contracts/domain-exports.json, workspace/fscrud-01/__tests__/domain.contract.test.js, workspace/fscrud-01/data/seed.json, workspace/fscrud-01/scripts/check-domain-exports.cjs, workspace/fscrud-01/scripts/check-domain-customer.cjs, workspace/fscrud-01/scripts/check-domain-assets.cjs, workspace/fscrud-01/scripts/check-domain-work-orders.cjs"
  let allowed_files = "workspace/fscrud-01/src/server.js, workspace/fscrud-01/public/index.html, workspace/fscrud-01/README.md, workspace/fscrud-01/run-manifest.json, workspace/fscrud-01/verification-report.md"
  let task_contract = "FSCRUD-01 field-service work order tracker. Build customers, assets, and work_orders with list/create/read/edit/detail/delete flows; work_orders reference customerId and assetId; expose status open/scheduled/in_progress/completed/cancelled, completedAt, and priority low/normal/urgent. Domain logic already passes public checks and must not be edited."

  run: node -e "const fs=require('fs');const cp=require('child_process');const paths=['experiments/fullstack-crud-comparison/scaffold/write-scaffold-contract.cjs','../../../../../fullstack-crud-comparison/scaffold/write-scaffold-contract.cjs'];const script=paths.find((p)=>fs.existsSync(p));if(!script){console.error('scaffold script missing');process.exit(1)}const r=cp.spawnSync(process.execPath,[script,'workspace/fscrud-01'],{stdio:'inherit'});process.exit(r.status??1)" [timeout 60]
  run: node -e "const fs=require('fs');const cp=require('child_process');const paths=['experiments/fullstack-crud-comparison/scaffold/write-domain-kernel.cjs','../../../../../fullstack-crud-comparison/scaffold/write-domain-kernel.cjs'];const script=paths.find((p)=>fs.existsSync(p));if(!script){console.error('domain kernel script missing');process.exit(1)}const r=cp.spawnSync(process.execPath,[script,'workspace/fscrud-01'],{stdio:'inherit'});process.exit(r.status??1)" [timeout 60]
  run: cd workspace/fscrud-01 && npm run check:domain:exports && npm run check:domain:customer && npm run check:domain:assets && npm run check:domain:work-orders && npm test [timeout 300]
  run: node -e "const fs=require('fs');for(const p of ['workspace/fscrud-01/src/server.js','workspace/fscrud-01/public/index.html','workspace/fscrud-01/README.md','workspace/fscrud-01/run-manifest.json','workspace/fscrud-01/verification-report.md'])fs.rmSync(p,{force:true});" [timeout 60]

  prompt: Work only in ${fscrud_workspace}. Treat workspace/fscrud-01 as the app root. EXPERIMENT_ARM r31-pl-domain-kernel-bulk. PROVIDER local-only. The domain kernel is already implemented and green. Do not edit protected files: ${protected_files}. Create or repair only these files: ${allowed_files}. Use CommonJS server code that imports ./domain.js. Server and browser UI must visibly expose customers, assets, and work_orders with list, create, read, edit, detail, and delete flows. Include customerId, assetId, status, completedAt, and priority in server/UI text and behavior. README must document npm test and npm start. run-manifest.json must record deterministic-domain-kernel and local-only bulk. verification-report.md must list public checks run by the flow and say the hidden verifier is run only by the harness. Task contract: ${task_contract}.
  review strict criteria: "Local bulk files must exist, preserve the deterministic domain kernel, pass public domain checks and tests, and expose all server/UI terms." grounded-by 'node -e "const fs=require(\"fs\");if(fs.existsSync(\"src/domain.js\")){console.error(\"run_root_src_domain_leak\");process.exit(1)}for(const p of [\"workspace/fscrud-01/src/server.js\",\"workspace/fscrud-01/public/index.html\",\"workspace/fscrud-01/README.md\",\"workspace/fscrud-01/run-manifest.json\",\"workspace/fscrud-01/verification-report.md\"]){if(!fs.existsSync(p)){console.error(\"missing_allowed_file:\"+p);process.exit(1)}}const domain=fs.readFileSync(\"workspace/fscrud-01/src/domain.js\",\"utf8\");if(domain.includes(\"not implemented\")){console.error(\"domain_kernel_not_preserved\");process.exit(1)}const server=fs.readFileSync(\"workspace/fscrud-01/src/server.js\",\"utf8\").toLowerCase();const ui=fs.readFileSync(\"workspace/fscrud-01/public/index.html\",\"utf8\").toLowerCase();const text=server+\"\\n\"+ui;for(const term of [\"customers\",\"assets\",\"work_orders\",\"list\",\"create\",\"read\",\"edit\",\"detail\",\"delete\",\"customerid\",\"assetid\",\"status\",\"completedat\",\"priority\"]){if(!text.includes(term)){console.error(\"missing_public_surface_term:\"+term);process.exit(1)}}const manifest=fs.readFileSync(\"workspace/fscrud-01/run-manifest.json\",\"utf8\").toLowerCase();if(!manifest.includes(\"r31-pl-domain-kernel-bulk\")||!manifest.includes(\"deterministic-domain-kernel\")){console.error(\"manifest_missing_r31_kernel_labels\");process.exit(1)}" && cd workspace/fscrud-01 && npm run check:domain:exports && npm run check:domain:customer && npm run check:domain:assets && npm run check:domain:work-orders && npm test' max 3
    prompt: Work only in ${fscrud_workspace}. Treat workspace/fscrud-01 as the app root. Repair only these allowed files: ${allowed_files}. Do not edit protected files: ${protected_files}. Critique: ${_review_critique}
  end

  run: node -e "require('fs').writeFileSync('workspace/fscrud-01/.pl-r31-domain-kernel-bulk-complete','ok\n')" [timeout 60]

done when:
  file_exists workspace/fscrud-01/package.json
  file_exists workspace/fscrud-01/DOMAIN_API.md
  file_exists workspace/fscrud-01/contracts/domain-exports.json
  file_exists workspace/fscrud-01/README.md
  file_exists workspace/fscrud-01/src/domain.js
  file_exists workspace/fscrud-01/src/server.js
  file_exists workspace/fscrud-01/public/index.html
  file_exists workspace/fscrud-01/__tests__/domain.contract.test.js
  file_exists workspace/fscrud-01/data/seed.json
  file_exists workspace/fscrud-01/run-manifest.json
  file_exists workspace/fscrud-01/verification-report.md
  file_exists workspace/fscrud-01/.pl-r31-domain-kernel-bulk-complete

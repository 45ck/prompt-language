library: implementation

import "experiments/full-saas-factory/e7-enterprise-crm-factory/libraries/crud-entity.flow" as crud
import "experiments/full-saas-factory/e7-enterprise-crm-factory/libraries/database.flow" as database

export flow run(stack="Next.js 15 + TypeScript", db="PostgreSQL + Prisma", auth="NextAuth.js", pkg="pnpm", entities="contact company opportunity"):
  prompt: Phase 3 — Implementation. Stack: ${stack}. DB: ${db}. Auth: ${auth}. Build the CRM application in apps/web/ and packages/api/. Follow docs/api-contracts.md and docs/data-model.md exactly. Do not add features beyond the PRD scope.

  # Foundation: shared types + database + auth (must complete before entity work)
  spawn "shared-foundation" with vars stack, db, pkg
    prompt: Use agent: backend-engineer. Use skills: entity-model-designer, schema-normalizer. Create packages/shared/src/types/ with TypeScript interfaces for all 15 business entities (contact, company, lead, deal, quote, invoice, product, line_item, contract, case, activity, task, note, email_template, campaign) plus system types (dashboard widget, report query, role, permission, audit log entry) matching docs/data-model.md. Create packages/shared/src/validation/ with Zod schemas for each entity. Create packages/shared/src/constants/ with pipeline stage enums, permission enums, and entity status enums. Export everything from packages/shared/src/index.ts.
    run: cd packages/shared && ${pkg} build
    retry max 2
      run: cd packages/shared && ${pkg} typecheck
      if command_failed
        prompt: Fix type errors in packages/shared. Check the error output and align types with docs/data-model.md.
      end
    end
  end

  spawn "database-setup" with vars db, pkg
    prompt: Use agent: backend-engineer. Use skills: entity-model-designer, repository-layer-designer, schema-normalizer. Write packages/api/prisma/schema.prisma matching docs/data-model.md exactly — all 15 business entities plus system tables (role, permission, audit_log, pipeline_stage, dashboard_widget, saved_report) with relations, indexes, unique constraints, enums, and cascade rules. Include created_at/updated_at/deleted_at (soft delete) on all business entities. Audit log and pipeline stage tables should NOT have soft delete — audit is append-only, pipeline stages are admin-managed config.
    use database.setup_schema(pkg="${pkg}")
    use database.seed_data(pkg="${pkg}")
  end

  spawn "auth-system" with vars auth, pkg
    prompt: Use agent: backend-engineer. Use skills: entity-model-designer, transaction-boundary-checker. Implement auth using ${auth} in packages/api/src/auth/. Include: email/password registration with bcrypt, OAuth (Google, GitHub), session management, RBAC middleware (roles: admin, manager, rep, viewer), permission checks per entity, password reset flow, and email verification stubs. Write packages/api/src/auth/middleware.ts, packages/api/src/auth/providers.ts, packages/api/src/auth/rbac.ts.
    retry max 3
      run: cd packages/api && ${pkg} test -- --grep auth
      if command_failed
        prompt: Fix failing auth tests. Check test output and ensure RBAC, session, and provider tests pass.
      end
    end
  end

  await all

  # Backend API layer (depends on foundation)
  spawn "backend-api" with vars stack, db, pkg
    prompt: Use agent: backend-engineer. Use skills: api-contract-writer, api-error-model-designer, repository-layer-designer, transaction-boundary-checker. Implement the REST API in packages/api/src/routes/ following docs/api-contracts.md. Include: standardized error responses, pagination (cursor-based), filtering, sorting, bulk operations, and request validation using Zod schemas from packages/shared. Write repository layer in packages/api/src/repositories/ with Prisma queries. Implement service layer in packages/api/src/services/ with business logic and transaction boundaries.
    review criteria: "API must match docs/api-contracts.md. All endpoints must validate input, handle errors, enforce RBAC, and return consistent response shapes." grounded-by "cd packages/api && ${pkg} test" max 3
      prompt: Use agent: backend-engineer. Review API implementation against the contracts. Fix missing endpoints, incorrect validation, broken error handling, or RBAC gaps.
    end
  end

  # Frontend shell (can start parallel with backend API)
  spawn "frontend-shell" with vars stack, pkg
    prompt: Use agent: web-engineer. Use skills: route-and-controller-planner, client-server-responsibility-splitter, form-validation-designer, mvc-boundary-checker. Build the Next.js 15 app shell in apps/web/ following docs/architecture/frontend-architecture.md and docs/architecture/routing-map.md. Include: app router layout with sidebar navigation, auth pages (sign-in, sign-up, forgot-password), dashboard layout, shared UI components (data tables, forms, modals, toasts, pagination, search), and API client setup (React Query + fetch wrapper). Use Tailwind CSS + Radix UI primitives for accessible components.
    retry max 2
      run: cd apps/web && ${pkg} build
      if command_failed
        prompt: Fix build errors in the frontend shell. Check the error output.
      end
    end
  end

  await all

  # Entity CRUD generation — parallel per entity cluster (business entities only)
  let core_entities = "contact company lead deal"
  let commerce_entities = "quote invoice product line_item contract"
  let activity_entities = "activity task note case"
  let comm_entities = "email_template campaign"

  foreach-spawn cluster in "core commerce activity comms" max 4
    if ${cluster} == "core"
      foreach entity in "${core_entities}"
        use crud.generate_full(entity="${entity}", pkg="${pkg}")
      end
    end
    if ${cluster} == "commerce"
      foreach entity in "${commerce_entities}"
        use crud.generate_full(entity="${entity}", pkg="${pkg}")
      end
    end
    if ${cluster} == "activity"
      foreach entity in "${activity_entities}"
        use crud.generate_full(entity="${entity}", pkg="${pkg}")
      end
    end
    if ${cluster} == "comms"
      foreach entity in "${comm_entities}"
        use crud.generate_full(entity="${entity}", pkg="${pkg}")
      end
    end
  end
  await all

  # System features — specialized modules (NOT generic CRUD)
  spawn "system-pipeline-config" with vars pkg
    prompt: Use agent: backend-engineer. Use skills: entity-model-designer. Implement pipeline stage configuration as an admin-only module. Pipeline stages are an ordered enum/config (e.g., Prospect, Qualified, Proposal, Negotiation, Closed Won, Closed Lost) — not user-created CRUD records. Create packages/api/src/modules/pipeline/pipeline-config.service.ts (read stages, reorder stages — admin only), packages/api/src/modules/pipeline/pipeline-config.routes.ts (GET /api/pipeline-stages, PUT /api/pipeline-stages/reorder — admin RBAC), and apps/web/src/app/(dashboard)/settings/pipeline/page.tsx (drag-to-reorder admin UI). Write tests.
  end

  spawn "system-dashboard" with vars pkg
    prompt: Use agent: web-engineer. Use skills: route-and-controller-planner, client-server-responsibility-splitter. Implement the dashboard as a widget-based framework — not a CRUD entity. Create packages/api/src/modules/dashboard/dashboard.service.ts (aggregate queries: total contacts, total companies, deals by stage, revenue from invoices, overdue tasks, recent activity feed), packages/api/src/modules/dashboard/dashboard.routes.ts (GET /api/dashboard/widgets, GET /api/dashboard/stats), and apps/web/src/app/(dashboard)/page.tsx (widget grid with charts, KPI cards, activity timeline). Dashboards are rendered from live queries, not stored as editable records. Write tests.
  end

  spawn "system-reports" with vars pkg
    prompt: Use agent: backend-engineer. Use skills: api-contract-writer, repository-layer-designer. Implement the report engine as a query-based generation module — not a CRUD entity. Create packages/api/src/modules/reports/report.service.ts (pre-defined report types: sales pipeline, revenue forecast, activity summary, contact growth — each runs an aggregate query), packages/api/src/modules/reports/report.routes.ts (GET /api/reports/:type with date range and filter params, GET /api/reports/types), and apps/web/src/app/(dashboard)/reports/page.tsx (report type selector, date range picker, table/chart output). Reports are generated on demand, not stored. Users can optionally save report configs as "saved reports". Write tests.
  end

  spawn "system-rbac" with vars pkg
    prompt: Use agent: backend-engineer. Use skills: entity-model-designer, transaction-boundary-checker. Implement RBAC as a fixed role/permission matrix — not user-created CRUD records. Roles are a fixed set (admin, manager, rep, viewer). Permissions are computed from role, not individually editable. Create packages/api/src/modules/rbac/rbac.service.ts (check permission, list roles, assign role to user), packages/api/src/modules/rbac/rbac.middleware.ts (Express/Hono middleware for route-level permission checks), packages/api/src/modules/rbac/permission-matrix.ts (static role→permission mapping), and apps/web/src/app/(dashboard)/settings/roles/page.tsx (role assignment UI — admin only). Write tests.
  end

  spawn "system-audit" with vars pkg
    prompt: Use agent: backend-engineer. Use skills: entity-model-designer, repository-layer-designer. Implement audit log as an append-only logger — not a CRUD entity with update/delete. Create packages/api/src/modules/audit/audit.service.ts (log entry creation with actor, action, entity type, entity ID, timestamp, diff), packages/api/src/modules/audit/audit.middleware.ts (auto-log all CUD operations on business entities), packages/api/src/modules/audit/audit.routes.ts (GET /api/audit-log with pagination and filters — read-only, admin/manager only), and apps/web/src/app/(dashboard)/settings/audit/page.tsx (searchable audit log viewer). No update or delete endpoints. Write tests.
  end

  await all

  # Integration wiring — connect all entities and system features to the frontend shell
  prompt: Use agent: web-engineer. Use skills: route-and-controller-planner, form-validation-designer. Wire all entity pages and system feature pages into the sidebar navigation. Ensure the dashboard page shows: total contacts, total companies, deals by pipeline stage, total revenue from invoices, overdue tasks, open cases, and recent activity feed. Verify all routes from docs/architecture/routing-map.md are implemented.

  # Full build verification
  retry max 3
    run: ${pkg} lint
    run: ${pkg} typecheck
    run: ${pkg} test
    if command_failed
      prompt: Fix all lint, type, and test failures. Check the error output and fix each issue. Do not disable rules or skip tests.
    end
  end
